// getCat hanya dipakai untuk grid sidebar warna & soal normal (berurutan TWK/TIU/TKP)
function getCat(n){
  if(n<=30)return{name:'TWK',cls:'twk'};
  if(n<=65)return{name:'TIU',cls:'tiu'};
  return{name:'TKP',cls:'tkp'};
}

// Mendapatkan kategori soal: gunakan field kategori jika ada, fallback ke posisi
function getKategoriSoal(idx){
  // Ambil dari questions[idx].kategori (sudah di-copy dari originals saat shuffleOpts)
  return questions[idx]&&questions[idx].kategori ? questions[idx].kategori : getCat(idx+1).name;
}

function shuffleOpts(q){
  // Salin kategori ke hasil shuffle agar tidak hilang
  const kat = q.kategori || 'TKP';
  if(q.isTKP){
    let p=q.options.map((t,i)=>({text:t,score:q.optionScores[i]}));
    for(let i=p.length-1;i>0;i--){let j=Math.floor(Math.random()*(i+1));[p[i],p[j]]=[p[j],p[i]];}
    return{
      question:q.question,
      options:p.map(x=>x.text),
      answer:null,
      isTKP:true,
      optionScores:p.map(x=>x.score),
      pembahasan:q.pembahasan||'',
      kategori:kat   // ← PENTING: selalu ikut
    };
  } else {
    let p=q.options.map((t,i)=>({text:t,idx:i}));
    for(let i=p.length-1;i>0;i--){let j=Math.floor(Math.random()*(i+1));[p[i],p[j]]=[p[j],p[i]];}
    return{
      question:q.question,
      options:p.map(x=>x.text),
      answer:p.findIndex(x=>x.idx===q.answer),
      isTKP:false,
      optionScores:null,
      pembahasan:q.pembahasan||'',
      kategori:kat   // ← PENTING: selalu ikut
    };
  }
}

function getSoalBank(id){
  const v='paket'+id;
  return typeof window[v]!=='undefined'?window[v]:{twk:[],tiu:[],tkp:[]};
}

function buildOriginals(id){
  const bank=getSoalBank(id),orig=[];
  bank.twk.forEach(d=>orig.push({
    question:d.q,options:[...d.opt],answer:d.a,
    isTKP:false,optionScores:null,pembahasan:d.pembahasan||'',
    kategori:'TWK'
  }));
  bank.tiu.forEach(d=>orig.push({
    question:d.q,options:[...d.opt],answer:d.a,
    isTKP:false,optionScores:null,pembahasan:d.pembahasan||'',
    kategori:'TIU'
  }));
  bank.tkp.forEach(d=>orig.push({
    question:d.q,options:[...d.opts],answer:null,
    isTKP:true,optionScores:[...d.scores],pembahasan:d.pembahasan||'',
    kategori:'TKP'
  }));
  return orig;
}

// ==================== HITUNG SKOR ====================
// Untuk latihan normal (urutan tetap TWK 1-30, TIU 31-65, TKP 66-110)
function hitungSkor(){
  let twk=0,tiu=0,tkp=0;
  for(let i=0;i<questions.length;i++){
    const n=i+1;
    if(n<=30){if(userAnswers[i]!==null&&userAnswers[i]===questions[i].answer)twk+=5;}
    else if(n<=65){if(userAnswers[i]!==null&&userAnswers[i]===questions[i].answer)tiu+=5;}
    else{if(userScores[i]!==null)tkp+=userScores[i];}
  }
  return{twk,tiu,tkp,total:twk+tiu+tkp,persen:Math.round((twk+tiu+tkp)/550*100)};
}

// Untuk soal salah & simulasi: gunakan field kategori di setiap soal
function hitungSkorByKategori(){
  let twk=0,tiu=0,tkp=0;
  for(let i=0;i<questions.length;i++){
    const q=questions[i];
    const kat=q.kategori||'TKP';
    if(q.isTKP){
      // TKP: tambahkan skor yang dipilih user (bukan hanya skor maksimal)
      if(userScores[i]!==null && userScores[i]!==undefined){
        tkp+=userScores[i];
      }
    } else {
      if(userAnswers[i]!==null && userAnswers[i]===q.answer){
        if(kat==='TWK') twk+=5;
        else if(kat==='TIU') tiu+=5;
        else tkp+=5; // fallback
      }
    }
  }
  const total=twk+tiu+tkp;
  // Hitung skor maks dinamis dari soal yang ada
  let mTWK=0,mTIU=0,mTKP=0;
  questions.forEach(q=>{
    const kat=q.kategori||'TKP';
    if(q.isTKP){
      // Skor maks TKP per soal = nilai tertinggi dari optionScores
      const mx=q.optionScores?Math.max(...q.optionScores):5;
      mTKP+=mx;
    } else {
      if(kat==='TWK') mTWK+=5;
      else if(kat==='TIU') mTIU+=5;
    }
  });
  const mTot=mTWK+mTIU+mTKP;
  const persen=mTot>0?Math.round(total/mTot*100):0;
  return{twk,tiu,tkp,total,persen,mTWK,mTIU,mTKP,mTot};
}

// ==================== SOAL SALAH ====================
function getSoalSalahList(){
  let list=[];
  try{const d=localStorage.getItem('soalSalahData');if(d)list=JSON.parse(d);}catch(e){}
  return list;
}

function saveSoalSalah(newWrong){
  let list=getSoalSalahList();
  newWrong.forEach(q=>{
    const exists=list.some(x=>x.question===q.question);
    if(!exists)list.push(q);
  });
  localStorage.setItem('soalSalahData',JSON.stringify(list));
}

function hapusDariSoalSalah(benarList){
  let list=getSoalSalahList();
  benarList.forEach(q=>{
    list=list.filter(x=>x.question!==q.question);
  });
  localStorage.setItem('soalSalahData',JSON.stringify(list));
}

function refreshSoalSalahInfo(){
  const list=getSoalSalahList();
  const info=document.getElementById('soalSalahInfo');
  const btn=document.getElementById('btnMulaiSoalSalah');
  if(list.length===0){
    info.textContent='Belum ada soal yang salah. Kerjakan latihan terlebih dahulu!';
    btn.disabled=true;
  } else {
    // Hitung berapa TWK/TIU/TKP
    let cTWK=0,cTIU=0,cTKP=0;
    list.forEach(q=>{
      const k=q.kategori||'TKP';
      if(k==='TWK')cTWK++;
      else if(k==='TIU')cTIU++;
      else cTKP++;
    });
    info.innerHTML=`Terdapat <strong>${list.length} soal</strong> yang pernah dijawab salah.<br>
      <span style="font-size:11px;color:#7c3aed;">📚 TWK: ${cTWK}</span> &nbsp;
      <span style="font-size:11px;color:#b45309;">🔢 TIU: ${cTIU}</span> &nbsp;
      <span style="font-size:11px;color:#059669;">⭐ TKP: ${cTKP}</span>`;
    btn.disabled=false;
  }
}

function mulaiSoalSalah(){
  const list=getSoalSalahList();
  if(list.length===0){alert('Belum ada soal salah!');return;}
  if(timerInterval){clearInterval(timerInterval);timerInterval=null;}
  // Pastikan semua soal punya kategori
  originals=list.map(q=>({
    ...q,
    kategori: q.kategori || 'TKP' // fallback jika data lama tidak punya kategori
  }));
  questions=originals.map(q=>shuffleOpts(q));
  curQ=0;
  userAnswers=Array(questions.length).fill(null);
  userScores=Array(questions.length).fill(null);
  timeLeft=6000;
  simulasiMode=false;
  soalSalahMode=true;
  activeSet=0;
  document.getElementById('evaluasiPanel').style.display='none';
  document.getElementById('btnCloseEval').style.display='none';
  document.getElementById('quizTitle').textContent='🔁 Latihan Soal Salah';
  document.getElementById('sidebarToggle').style.display='block';
  goTo('quizPage');
  loadQuestion();
  updateGrid();
  const td=document.getElementById('timerDisplay');
  const tb=document.getElementById('timerBadge');
  td.textContent='--:--';td.style.opacity='0';
  tb.textContent='';tb.className='timer-badge off';
  tb.style.display='none';
}

