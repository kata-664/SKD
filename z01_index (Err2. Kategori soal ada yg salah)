    if(twk&&tiu&&tkp){
      totalLatihan++;
      const t=parseInt(twk)||0,u=parseInt(tiu)||0,k=parseInt(tkp)||0,tot=t+u+k;
      const lulus=t>=65&&u>=80&&k>=166;
      if(lulus)totalLulus++;
      if(tot>bestOverall)bestOverall=tot;
      const bank=getSoalBank(i);
      rows.push({paket:i,twk:t,tiu:u,tkp:k,total:tot,lulus,max:(bank.twk.length*5)+(bank.tiu.length*5)+(bank.tkp.length*5)});
      chartLabels.push('Paket '+i);
      chartData.push(tot);
    }
  }
  document.getElementById('statsOverview').innerHTML=`
    <div class="stats-mini-card"><div class="mini-icon">📝</div><div class="mini-value">${totalLatihan}/5</div><div class="mini-label">Paket Selesai</div></div>
    <div class="stats-mini-card"><div class="mini-icon">🏆</div><div class="mini-value">${bestOverall||'-'}</div><div class="mini-label">Skor Terbaik</div></div>
    <div class="stats-mini-card"><div class="mini-icon">🎯</div><div class="mini-value">${totalLulus}/${totalLatihan||1}</div><div class="mini-label">Lulus PG</div></div>`;
  let mTWK=0,mTIU=0,mTKP=0;
  rows.forEach(r=>{if(r.twk>mTWK)mTWK=r.twk;if(r.tiu>mTIU)mTIU=r.tiu;if(r.tkp>mTKP)mTKP=r.tkp;});
  const twkP=mTWK>0?Math.round(mTWK/150*100):0;
  const tiuP=mTIU>0?Math.round(mTIU/175*100):0;
  const tkpP=mTKP>0?Math.round(mTKP/225*100):0;
  document.getElementById('statsBars').innerHTML=`
    <h4 style="margin-bottom:8px;color:var(--dark);font-size:13px;font-weight:700;">📊 Penguasaan per Kategori</h4>
    <div class="stats-bar-container"><div class="stats-bar-label"><span>📚 TWK</span><span>${mTWK}/150 (${twkP}%)</span></div><div class="stats-bar"><div class="stats-bar-fill twk" style="width:${twkP}%">${twkP}%</div></div></div>
    <div class="stats-bar-container"><div class="stats-bar-label"><span>🔢 TIU</span><span>${mTIU}/175 (${tiuP}%)</span></div><div class="stats-bar"><div class="stats-bar-fill tiu" style="width:${tiuP}%">${tiuP}%</div></div></div>
    <div class="stats-bar-container"><div class="stats-bar-label"><span>⭐ TKP</span><span>${mTKP}/225 (${tkpP}%)</span></div><div class="stats-bar"><div class="stats-bar-fill tkp" style="width:${tkpP}%">${tkpP}%</div></div></div>`;
  const cc=document.getElementById('chartContainer');
  if(chartData.length>0){
    cc.style.display='block';
    const ctx=document.getElementById('progressChart').getContext('2d');
    if(chartInstance)chartInstance.destroy();
    chartInstance=new (function(){
      const W=ctx.canvas.width=ctx.canvas.offsetWidth||300;
      const H=ctx.canvas.height=180;
      const pad={top:20,right:20,bottom:30,left:40};
      const cw=W-pad.left-pad.right,ch=H-pad.top-pad.bottom;
      const maxV=550;
      ctx.clearRect(0,0,W,H);
      ctx.strokeStyle='#e2e8f0';ctx.lineWidth=1;
      [0,138,275,413,550].forEach(v=>{
        const y=pad.top+ch-(v/maxV)*ch;
        ctx.beginPath();ctx.moveTo(pad.left,y);ctx.lineTo(pad.left+cw,y);ctx.stroke();
        ctx.fillStyle='#94a3b8';ctx.font='10px Arial';ctx.textAlign='right';
        ctx.fillText(v,pad.left-4,y+3);
      });
      const pgY=pad.top+ch-(311/maxV)*ch;
      ctx.strokeStyle='#fca5a5';ctx.lineWidth=1.5;ctx.setLineDash([4,4]);
      ctx.beginPath();ctx.moveTo(pad.left,pgY);ctx.lineTo(pad.left+cw,pgY);ctx.stroke();
      ctx.setLineDash([]);
      ctx.fillStyle='#dc2626';ctx.font='10px Arial';ctx.textAlign='left';
      ctx.fillText('PG',pad.left+2,pgY-3);
      const bw=Math.min(40,(cw/chartData.length)*0.6);
      const gap=(cw-bw*chartData.length)/(chartData.length+1);
      chartData.forEach((v,i)=>{
        const x=pad.left+gap+(bw+gap)*i;
        const bh=(v/maxV)*ch;
        const y=pad.top+ch-bh;
        const grad=ctx.createLinearGradient(0,y,0,y+bh);
        grad.addColorStop(0,'#3b82f6');grad.addColorStop(1,'#7c3aed');
        ctx.fillStyle=grad;
        ctx.beginPath();
        ctx.roundRect?ctx.roundRect(x,y,bw,bh,4):ctx.rect(x,y,bw,bh);
        ctx.fill();
        ctx.fillStyle='#334155';ctx.font='bold 11px Arial';ctx.textAlign='center';
        ctx.fillText(v,x+bw/2,y-4);
        ctx.fillStyle='#64748b';ctx.font='10px Arial';
        ctx.fillText(chartLabels[i],x+bw/2,H-pad.bottom+14);
      });
      this.destroy=function(){ctx.clearRect(0,0,W,H);};
    })();
  } else {
    cc.style.display='none';
  }
  let hHtml='<h4 style="margin-bottom:8px;color:var(--dark);font-size:13px;font-weight:700;">📋 Riwayat Latihan</h4>';
  if(rows.length>0){
    hHtml+=`<table class="stats-history-table"><tr><th>Paket</th><th>TWK</th><th>TIU</th><th>TKP</th><th>Total</th><th>Status</th></tr>`;
    rows.forEach(r=>{
      hHtml+=`<tr><td>Paket ${r.paket}</td><td>${r.twk}</td><td>${r.tiu}</td><td>${r.tkp}</td><td>${r.total}/${r.max}</td><td class="${r.lulus?'pass':'fail'}">${r.lulus?'✅ Lulus':'❌ Gagal'}</td></tr>`;
    });
    hHtml+='</table>';
  } else {
    hHtml+='<p style="color:#94a3b8;text-align:center;padding:20px;">Belum ada riwayat latihan.</p>';
  }
  document.getElementById('statsHistory').innerHTML=hHtml;
}

// ==================== SIMULASI ====================
function mulaiSimulasi(){
  const allTWK=[],allTIU=[],allTKP=[];
  for(let i=1;i<=5;i++){const b=getSoalBank(i);allTWK.push(...b.twk);allTIU.push(...b.tiu);allTKP.push(...b.tkp);}
  const pick=(arr,n)=>[...arr].sort(()=>Math.random()-.5).slice(0,Math.min(n,arr.length));
  const sTWK=pick(allTWK,30),sTIU=pick(allTIU,35),sTKP=pick(allTKP,45);
  if(sTWK.length+sTIU.length+sTKP.length===0){alert('⚠️ Tidak ada soal tersedia!');return;}
  if(timerInterval){clearInterval(timerInterval);timerInterval=null;}
  originals=[];
  sTWK.forEach(d=>originals.push({question:d.q,options:[...d.opt],answer:d.a,isTKP:false,optionScores:null,pembahasan:d.pembahasan||'',kategori:'TWK'}));
  sTIU.forEach(d=>originals.push({question:d.q,options:[...d.opt],answer:d.a,isTKP:false,optionScores:null,pembahasan:d.pembahasan||'',kategori:'TIU'}));
  sTKP.forEach(d=>originals.push({question:d.q,options:[...d.opts],answer:null,isTKP:true,optionScores:[...d.scores],pembahasan:d.pembahasan||'',kategori:'TKP'}));
  questions=originals.map(q=>shuffleOpts(q));
  curQ=0;userAnswers=Array(questions.length).fill(null);userScores=Array(questions.length).fill(null);
  timeLeft=6000;simulasiMode=true;soalSalahMode=false;activeSet=0;
  document.getElementById('evaluasiPanel').style.display='none';
  document.getElementById('btnCloseEval').style.display='none';
  document.getElementById('quizTitle').textContent='⏰ Simulasi Ujian SKD';
  document.getElementById('sidebarToggle').style.display='block';
  goTo('quizPage');loadQuestion();updateGrid();
  const td=document.getElementById('timerDisplay'),tb=document.getElementById('timerBadge');
  td.textContent='100:00';td.style.opacity='1';
  td.classList.remove('timer-warning','timer-danger','timer-blink');
  tb.textContent='⏱️ Simulasi';tb.className='timer-badge on';tb.style.display='';
  startTimer();
}

// ==================== START QUIZ ====================
function startQuiz(setId){
  if(timerInterval){clearInterval(timerInterval);timerInterval=null;}
  const bank=getSoalBank(setId);
  if(bank.twk.length+bank.tiu.length+bank.tkp.length===0){
    alert(`⚠️ Paket ${setId} belum tersedia.`);return;
  }
  activeSet=setId;simulasiMode=false;soalSalahMode=false;
  originals=buildOriginals(setId);
  questions=originals.map(q=>shuffleOpts(q));
  curQ=0;userAnswers=Array(questions.length).fill(null);userScores=Array(questions.length).fill(null);
  timeLeft=6000;
  document.getElementById('evaluasiPanel').style.display='none';
  document.getElementById('btnCloseEval').style.display='none';
  document.getElementById('quizTitle').textContent=`📖 Latihan SKD Paket ${setId}`;
  document.getElementById('sidebarToggle').style.display='block';
  goTo('quizPage');loadQuestion();updateGrid();
  const timerOn=getTimerEnabled();
  const td=document.getElementById('timerDisplay'),tb=document.getElementById('timerBadge');
  tb.style.display='';
  if(timerOn){
    td.textContent='100:00';td.style.opacity='1';
    td.classList.remove('timer-warning','timer-danger','timer-blink');
    tb.textContent='⏱️ Timer ON';tb.className='timer-badge on';startTimer();
  } else {
    td.textContent='100:00';td.style.opacity='.5';
    tb.textContent='⏸️ Timer OFF';tb.className='timer-badge off';
  }
}

// ==================== LOAD QUESTION ====================
function loadQuestion(){
  const n=curQ+1;
  document.getElementById('quizProgress').textContent=`Soal ${n}/${questions.length}`;
  document.getElementById('quizQuestion').innerHTML=questions[curQ].question;

  // Tampilkan kategori soal berdasarkan field kategori, bukan posisi
  const kat=questions[curQ].kategori||getCat(n).name;
  const katCls=kat.toLowerCase();
  const hc=document.getElementById('quizHeaderCat');
  hc.textContent=`📍 ${kat}`;
  hc.className=`header-cat ${katCls}`;

  let html='';
  questions[curQ].options.forEach((opt,idx)=>{
    let checked=questions[curQ].isTKP?(userScores[curQ]===questions[curQ].optionScores[idx]):(userAnswers[curQ]===idx);
    html+=`<label class="option"><input type="radio" name="ans" value="${idx}" ${checked?'checked':''}><span class="choice-letter">${PREFIXES[idx]}</span><span class="choice-text">${opt}</span></label>`;
  });
  document.getElementById('quizOptions').innerHTML=html;
  const btn=document.getElementById('btnNextFinish');
  if(curQ===questions.length-1){btn.textContent='✅ Selesai';btn.className='btn-finish';btn.style.flex='1';btn.onclick=finishQuiz;}
  else{btn.textContent='Next ▶';btn.className='btn-next';btn.style.flex='1';btn.onclick=nextQuestion;}
  updateGrid();
}

function saveAnswer(){
  const sel=document.querySelector('input[name="ans"]:checked');
  if(sel){
    const idx=parseInt(sel.value);
    if(questions[curQ].isTKP){
      userScores[curQ]=questions[curQ].optionScores[idx];
    } else {
      userAnswers[curQ]=idx;
    }
    updateGrid();
  }
}

function nextQuestion(){saveAnswer();if(curQ<questions.length-1){curQ++;loadQuestion();}}
function prevQuestion(){saveAnswer();if(curQ>0){curQ--;loadQuestion();}}

// ==================== TIMER ====================
function startTimer(){
  if(timerInterval)clearInterval(timerInterval);
  timerInterval=setInterval(()=>{
    if(timeLeft<=0){clearInterval(timerInterval);finishQuiz();return;}
    timeLeft--;
    const m=Math.floor(timeLeft/60),s=timeLeft%60;
    const el=document.getElementById('timerDisplay');
    el.textContent=`${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
    el.classList.remove('timer-warning','timer-danger','timer-blink');
    if(timeLeft<=20)el.classList.add('timer-blink');
    else if(timeLeft<=120)el.classList.add('timer-danger');
    else if(timeLeft<=300)el.classList.add('timer-warning');
  },1000);
}

// ==================== GRID ====================
function updateGrid(){
  const grid=document.getElementById('soalGrid');if(!grid)return;
  let html='';
  for(let i=0;i<questions.length;i++){
    let st='unanswered';
    if(questions[i].isTKP){if(userScores[i]!==null&&userScores[i]!==undefined)st='answered';}
    else{if(userAnswers[i]!==null)st='answered';}
    if(i===curQ)st='active';
    // Warna grid berdasarkan kategori soal, bukan posisi
    const kat=(questions[i].kategori||getCat(i+1).name).toLowerCase();
    html+=`<div class="grid-soal ${st} ${kat}" onclick="goToSoal(${i})">${i+1}</div>`;
  }
  grid.innerHTML=html;
}

function goToSoal(i){saveAnswer();curQ=i;loadQuestion();toggleSidebar();}
function toggleSidebar(){
  const sb=document.getElementById('sidebar'),ov=document.getElementById('overlay');
  const isOpen=sb.classList.toggle('open');
  if(isOpen){ov.style.width=`calc(100% - ${sb.offsetWidth}px)`;ov.classList.add('show');}
  else{ov.style.width='';ov.classList.remove('show');}
}

// ==================== FINISH ====================
function finishQuiz(){
  if(timerInterval){clearInterval(timerInterval);timerInterval=null;}
  saveAnswer();
  document.getElementById('sidebarToggle').style.display='none';

  const wasSoalSalah=soalSalahMode;
  const wasSimulasi=simulasiMode;

  // Hitung skor sesuai mode
  let s;
  if(!wasSoalSalah && !wasSimulasi){
    // Latihan normal: posisi menentukan kategori (TWK 1-30, TIU 31-65, TKP 66-110)
    s=hitungSkor();
    const bank=getSoalBank(activeSet);
    s.mTWK=bank.twk.length*5||150;
    s.mTIU=bank.tiu.length*5||175;
    s.mTKP=bank.tkp.length*5||225;
    s.mTot=s.mTWK+s.mTIU+s.mTKP;
  } else {
    // Soal salah atau simulasi: kategori dari field soal
    s=hitungSkorByKategori();
  }

  // Kumpulkan soal salah & benar untuk update bank soal salah
  const newWrong=[];
  const benarList=[];
  for(let i=0;i<questions.length;i++){
    const q=questions[i];
    let isBenar=false;
    if(q.isTKP){
      if(userScores[i]!==null&&userScores[i]!==undefined){
        const maxS=Math.max(...q.optionScores);
        isBenar=userScores[i]===maxS;
      }
    } else {
      isBenar=userAnswers[i]!==null&&userAnswers[i]===q.answer;
    }
    if(!wasSimulasi){
      if(!isBenar){
        const kat=q.kategori||(originals[i]&&originals[i].kategori)||getCat(i+1).name;
        newWrong.push({
          question:q.question,
          options:q.options,
          answer:q.answer,
          isTKP:q.isTKP,
          optionScores:q.optionScores,
          pembahasan:q.pembahasan||'',
          kategori:kat
        });
      } else {
        benarList.push(q);
      }
    }
  }

  if(!wasSimulasi&&!wasSoalSalah){
    saveSoalSalah(newWrong);
    hapusDariSoalSalah(benarList);
  }
  if(wasSoalSalah){
    // Hapus yang sudah benar, tambahkan yang masih salah ke bank
    hapusDariSoalSalah(benarList);
    // Update soal yang masih salah (bisa saja optionScores teracak ulang, simpan aslinya)
    // Tidak perlu re-save newWrong karena sudah ada di bank, hanya hapus yang benar
  }

  if(wasSimulasi){
    localStorage.setItem('simulasi_last',JSON.stringify({
      twk:s.twk,tiu:s.tiu,tkp:s.tkp,total:s.total,
      persen:s.persen,tanggal:new Date().toLocaleDateString('id-ID')
    }));
    simulasiMode=false;
  } else if(!wasSoalSalah){
    localStorage.setItem(`skorTWK_latihan${activeSet}`,s.twk);
    localStorage.setItem(`skorTIU_latihan${activeSet}`,s.tiu);
    localStorage.setItem(`skorTKP_latihan${activeSet}`,s.tkp);
    const ed={
      answers:userAnswers,
      scores:userScores,
      questions:questions.map(q=>({
        question:q.question,options:q.options,answer:q.answer,
        isTKP:q.isTKP,optionScores:q.optionScores,
        pembahasan:q.pembahasan||'',kategori:q.kategori||''
      }))
    };
    localStorage.setItem(`evalData_latihan${activeSet}`,JSON.stringify(ed));
    const key=`bestScore_latihan${activeSet}`;
    const prev=localStorage.getItem(key);
    if(prev===null||s.total>parseInt(prev))localStorage.setItem(key,s.total);
  }
  soalSalahMode=false;

  // ==================== TAMPILKAN HASIL ====================
  const mTWK=s.mTWK||150,mTIU=s.mTIU||175,mTKP=s.mTKP||225;
  const mTot=s.mTot||(mTWK+mTIU+mTKP);

  if(wasSoalSalah){
    document.getElementById('resultSubtitle').textContent='🔁 Hasil Latihan Soal Salah';
    document.getElementById('scoreDetail').innerHTML=`<h3>📊 Detail Skor</h3><table>
      <tr><td>📚 TWK</td><td><strong>${s.twk}</strong> / ${mTWK}</td></tr>
      <tr><td>🔢 TIU</td><td><strong>${s.tiu}</strong> / ${mTIU}</td></tr>
      <tr><td>⭐ TKP</td><td><strong>${s.tkp}</strong> / ${mTKP}</td></tr>
      <tr style="border-top:2px solid var(--border);"><td><strong>✅ TOTAL</strong></td><td><strong>${s.total}</strong> / ${mTot}</td></tr>
    </table><div class="total-score">🎯 Nilai: ${s.persen}%</div>`;
    document.getElementById('passStatus').style.display='none';
  } else {
    document.getElementById('resultSubtitle').textContent=wasSimulasi?'⏰ Hasil Simulasi SKD':`📝 Latihan SKD Paket ${activeSet}`;
    document.getElementById('scoreDetail').innerHTML=`<h3>📊 Detail Skor</h3><table>
      <tr><td>📚 TWK</td><td><strong>${s.twk}</strong> / ${mTWK}</td></tr>
      <tr><td>🔢 TIU</td><td><strong>${s.tiu}</strong> / ${mTIU}</td></tr>
      <tr><td>⭐ TKP</td><td><strong>${s.tkp}</strong> / ${mTKP}</td></tr>
      <tr style="border-top:2px solid var(--border);"><td><strong>✅ TOTAL</strong></td><td><strong>${s.total}</strong> / ${mTot}</td></tr>
    </table><div class="total-score">🎯 Nilai Akhir: ${s.persen}%</div>`;
    const pass={twk:s.twk>=PASSING.TWK,tiu:s.tiu>=PASSING.TIU,tkp:s.tkp>=PASSING.TKP};
    pass.all=pass.twk&&pass.tiu&&pass.tkp;
    document.getElementById('passStatus').style.display='';
    document.getElementById('passStatus').innerHTML=`
      <div style="margin-bottom:10px;font-weight:700;color:var(--dark);">📋 STATUS PASSING GRADE:</div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <div style="flex:1;text-align:center;padding:9px;border-radius:10px;background:${pass.twk?'#d1fae5':'#fee2e2'};font-size:13px;">📚 TWK: ${s.twk}/65<br><strong>${pass.twk?'✅ LULUS':'❌ GAGAL'}</strong></div>
        <div style="flex:1;text-align:center;padding:9px;border-radius:10px;background:${pass.tiu?'#d1fae5':'#fee2e2'};font-size:13px;">🔢 TIU: ${s.tiu}/80<br><strong>${pass.tiu?'✅ LULUS':'❌ GAGAL'}</strong></div>
        <div style="flex:1;text-align:center;padding:9px;border-radius:10px;background:${pass.tkp?'#d1fae5':'#fee2e2'};font-size:13px;">⭐ TKP: ${s.tkp}/166<br><strong>${pass.tkp?'✅ LULUS':'❌ GAGAL'}</strong></div>
      </div>
      <div style="margin-top:12px;padding:12px;border-radius:10px;background:${pass.all?'#d1fae5':'#fee2e2'};font-weight:700;font-size:14px;">
        ${pass.all?'🎉 SELAMAT! Anda LULUS Passing Grade SKD!':'⚠️ Belum lulus passing grade. Terus semangat berlatih!'}
      </div>`;
  }

  goTo('resultPage');
}

