// ==================== EVALUASI LIST ====================
function showEvaluasiFromList(setId){
  const bank=getSoalBank(setId);
  let savedAnswers=[],savedScores=[],savedQuestions=[];
  try{
    const d=localStorage.getItem(`evalData_latihan${setId}`);
    if(d){const p=JSON.parse(d);savedAnswers=p.answers||[];savedScores=p.scores||[];savedQuestions=p.questions||[];}
  }catch(e){}
  let eq=savedQuestions.length>0?savedQuestions:[];
  if(eq.length===0){
    bank.twk.forEach(d=>eq.push({question:d.q,options:[...d.opt],answer:d.a,isTKP:false,optionScores:null,pembahasan:d.pembahasan||'',kategori:'TWK'}));
    bank.tiu.forEach(d=>eq.push({question:d.q,options:[...d.opt],answer:d.a,isTKP:false,optionScores:null,pembahasan:d.pembahasan||'',kategori:'TIU'}));
    bank.tkp.forEach(d=>eq.push({question:d.q,options:[...d.opts],answer:null,isTKP:true,optionScores:[...d.scores],pembahasan:d.pembahasan||'',kategori:'TKP'}));
  }
  const sTWK=parseInt(localStorage.getItem(`skorTWK_latihan${setId}`))||0;
  const sTIU=parseInt(localStorage.getItem(`skorTIU_latihan${setId}`))||0;
  const sTKP=parseInt(localStorage.getItem(`skorTKP_latihan${setId}`))||0;
  const sTot=sTWK+sTIU+sTKP;
  const mTWK=bank.twk.length*5,mTIU=bank.tiu.length*5,mTKP=bank.tkp.length*5;
  const mTot=mTWK+mTIU+mTKP;
  document.getElementById('evalListTitle').textContent=`📖 Latihan SKD Paket ${setId}`;
  document.getElementById('evalListScoreSummary').innerHTML=`<div style="display:flex;gap:8px;flex-wrap:wrap;justify-content:center;">
    <span style="background:#ede9fe;padding:5px 12px;border-radius:20px;font-weight:700;font-size:12px;color:#7c3aed;">📚 TWK: ${sTWK}/${mTWK}</span>
    <span style="background:#fef3c7;padding:5px 12px;border-radius:20px;font-weight:700;font-size:12px;color:#b45309;">🔢 TIU: ${sTIU}/${mTIU}</span>
    <span style="background:#d1fae5;padding:5px 12px;border-radius:20px;font-weight:700;font-size:12px;color:#065f46;">⭐ TKP: ${sTKP}/${mTKP}</span>
    <span style="background:#dbeafe;padding:5px 12px;border-radius:20px;font-weight:700;font-size:12px;color:#1d4ed8;">✅ Total: ${sTot}/${mTot}</span>
  </div>`;
  let html='<h3 style="color:var(--primary);margin-bottom:12px;font-size:15px;">📝 Evaluasi Jawaban & Pembahasan</h3>';
  for(let i=0;i<eq.length;i++){
    const n=i+1,cat=getCat(n),q=eq[i],pb=q.pembahasan||'';
    let jawUser='Tidak dijawab',jawBenar='',stCls='belum',stIcon='⏳';
    if(q.isTKP){
      const uS=(savedScores[i]!==undefined&&savedScores[i]!==null)?savedScores[i]:null;
      if(uS!==null){
        const idx=q.optionScores.findIndex(s=>s===uS);
        jawUser=idx>=0?`${PREFIXES[idx]}. ${q.options[idx]} <span style="font-weight:700;color:#7c3aed">(Skor: ${uS})</span>`:'Tidak dijawab';
        const mS=Math.max(...q.optionScores),bIdx=q.optionScores.findIndex(s=>s===mS);
        jawBenar=`Jawaban terbaik: ${PREFIXES[bIdx]}. ${q.options[bIdx]} <strong>(Skor: ${mS})</strong>`;
        stCls=uS===mS?'benar':'salah';stIcon=uS===mS?'✅':'❌';
      }
    } else {
      const uA=(savedAnswers[i]!==undefined&&savedAnswers[i]!==null)?savedAnswers[i]:null;
      if(uA!==null){
        jawUser=`${PREFIXES[uA]}. ${q.options[uA]}`;
        jawBenar=`${PREFIXES[q.answer]}. ${q.options[q.answer]}`;
        stCls=uA===q.answer?'benar':'salah';stIcon=uA===q.answer?'✅':'❌';
      }
    }
    let stLabel=stCls==='benar'?'<span style="color:#059669;font-weight:700;font-size:12px;">✅ BENAR</span>':
      stCls==='salah'?'<span style="color:#dc2626;font-weight:700;font-size:12px;">❌ SALAH</span>':
      '<span style="color:#d97706;font-weight:700;font-size:12px;">⏳ BELUM</span>';
    html+=`<div class="evaluasi-item ${stCls}">
      <div class="soal-teks">${stIcon} Soal ${n} [${cat.name}] — ${stLabel}</div>
      <div class="soal-isi">${q.question}</div>
      <div class="jawaban-user">📌 <strong>Jawaban Anda:</strong> ${jawUser}</div>
      ${jawBenar?`<div class="jawaban-benar">✅ <strong>Jawaban Benar:</strong> ${jawBenar}</div>`:''}
      ${pb?`<div class="pembahasan-box"><strong>💡 Pembahasan</strong><br>${pb}</div>`:''}
    </div>`;
  }
  document.getElementById('evalListContent').innerHTML=html;
  goTo('evaluasiListPage');
}

