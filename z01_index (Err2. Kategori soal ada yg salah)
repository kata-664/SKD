<script>
// ==================== CEK FILE ====================
(function(){
  const vars=['paket1','paket2','paket3','paket4','paket5'];
  if(!vars.some(v=>typeof window[v]!=='undefined'))
    document.getElementById('errorNotice').style.display='block';
  const mv=['materiTWK','materiTIU','materiTKP'];
  if(!mv.some(v=>typeof window[v]!=='undefined'))
    document.getElementById('errorMateriNotice').style.display='block';
})();

// ==================== PROTECTION ====================
document.addEventListener('contextmenu',e=>e.preventDefault());
document.addEventListener('keydown',e=>{
  const k=e.key,c=e.ctrlKey,s=e.shiftKey;
  if(k==='F12'||(c&&s&&'ICJ'.includes(k))||(c&&'usp'.includes(k))||k==='PrintScreen'){e.preventDefault();flashOverlay();}
});
document.addEventListener('dragstart',e=>e.preventDefault());
document.addEventListener('copy',e=>e.preventDefault());
