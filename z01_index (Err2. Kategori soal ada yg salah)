<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>Latihan SKD CPNS</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:'Segoe UI',Arial,sans-serif;-webkit-tap-highlight-color:transparent;}
:root {
  --primary: #2563eb;
  --primary-dark: #1d4ed8;
  --primary-light: #dbeafe;
  --secondary: #7c3aed;
  --secondary-light: #ede9fe;
  --success: #059669;
  --success-light: #d1fae5;
  --danger: #dc2626;
  --danger-light: #fee2e2;
  --warning: #d97706;
  --warning-light: #fef3c7;
  --info: #0891b2;
  --info-light: #cffafe;
  --dark: #1e293b;
  --gray: #64748b;
  --gray-light: #f1f5f9;
  --white: #ffffff;
  --border: #e2e8f0;
  --shadow: 0 4px 24px rgba(37,99,235,.10);
  --radius: 20px;
  --radius-sm: 12px;
}
body{background:linear-gradient(135deg,#1e3a8a 0%,#4f46e5 50%,#7c3aed 100%);min-height:100vh;display:flex;justify-content:center;align-items:flex-start;padding:16px;user-select:none;-webkit-user-select:none;}
.page{display:none;width:100%;max-width:620px;}
.page.active{display:block;animation:fadeIn 0.3s ease;}
@keyframes fadeIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
.card{background:var(--white);border-radius:var(--radius);box-shadow:0 20px 60px rgba(30,58,138,.18);padding:22px;margin-bottom:20px;}
.logo{text-align:center;margin-bottom:18px;}
.logo .icon{margin-bottom:8px;}
.logo h1{background:linear-gradient(135deg,#2563eb,#7c3aed);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;font-size:24px;font-weight:800;margin-bottom:4px;}
.logo p{color:var(--gray);font-size:13px;}
.stats-card{background:linear-gradient(135deg,#eff6ff,#f5f3ff);border-radius:16px;padding:14px;margin:14px 0;display:flex;justify-content:space-around;text-align:center;border:1px solid var(--border);}
.stat-item .stat-number{font-size:22px;font-weight:800;color:var(--primary);}
.stat-item .stat-label{font-size:10px;color:var(--gray);margin-top:3px;font-weight:600;}
.menu-grid-6{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin:14px 0;}
.menu-card{border:none;border-radius:16px;padding:16px 8px;color:white;cursor:pointer;text-align:center;transition:.2s;display:flex;flex-direction:column;align-items:center;gap:6px;font-weight:700;box-shadow:0 4px 14px rgba(0,0,0,.15);}
.menu-card:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,.2);}
.menu-card:active{transform:scale(0.94);}
.menu-card .menu-icon{font-size:26px;}
.menu-card .menu-label{font-size:11px;font-weight:700;}
.menu-card.soal{background:linear-gradient(135deg,#059669,#10b981);}
.menu-card.simulasi{background:linear-gradient(135deg,#dc2626,#ef4444);}
.menu-card.stats{background:linear-gradient(135deg,#d97706,#f59e0b);}
.menu-card.materi{background:linear-gradient(135deg,#7c3aed,#a78bfa);}
.menu-card.petunjuk{background:linear-gradient(135deg,#0891b2,#22d3ee);}
.menu-card.tentang{background:linear-gradient(135deg,#2563eb,#60a5fa);}
.menu-card.pencapaian{background:linear-gradient(135deg,#b45309,#f59e0b);}
.menu-card.soal-salah{background:linear-gradient(135deg,#be185d,#ec4899);}
.info-acak{background:linear-gradient(135deg,#7c3aed,#a78bfa);padding:11px;border-radius:12px;font-size:11px;color:white;text-align:center;margin-top:10px;font-weight:700;}
.version{text-align:center;margin-top:12px;color:#94a3b8;font-size:11px;}
.page-title{margin-bottom:14px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;color:var(--dark);font-size:17px;font-weight:700;padding-bottom:10px;border-bottom:2px solid var(--border);}
.toggle-container{display:flex;align-items:center;gap:8px;font-size:11px;background:var(--gray-light);padding:4px 12px;border-radius:30px;}
.switch{position:relative;display:inline-block;width:42px;height:20px;}
.switch input{opacity:0;width:0;height:0;}
.slider{position:absolute;cursor:pointer;top:0;left:0;right:0;bottom:0;background:#cbd5e1;transition:.3s;border-radius:20px;}
.slider:before{position:absolute;content:"";height:14px;width:14px;left:3px;bottom:3px;background:white;transition:.3s;border-radius:50%;}
input:checked+.slider{background:var(--primary);}
input:checked+.slider:before{transform:translateX(22px);}
.timer-status{font-weight:700;font-size:10px;}
.timer-status.on{color:var(--success);}
.timer-status.off{color:var(--danger);}
.quiz-item{width:100%;background:white;border-radius:16px;margin-bottom:10px;cursor:pointer;transition:.2s;box-shadow:0 2px 10px rgba(0,0,0,.06);border:1px solid var(--border);overflow:hidden;}
.quiz-item:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.1);}
.quiz-header{display:flex;align-items:center;justify-content:space-between;padding:13px 14px;background:linear-gradient(135deg,#059669,#10b981);color:white;}
.quiz-left{display:flex;align-items:center;gap:10px;font-weight:700;font-size:14px;}
.quiz-icon{font-size:20px;}
.quiz-right{display:flex;gap:4px;flex-wrap:wrap;justify-content:flex-end;}
.skor-badge{padding:3px 8px;border-radius:30px;text-align:center;font-size:10px;font-weight:700;}
.skor-badge.twk{background:rgba(124,58,237,.9);color:white;}
.skor-badge.tiu{background:rgba(180,83,9,.9);color:white;}
.skor-badge.tkp{background:rgba(5,150,105,.9);color:white;}
.skor-badge.belum{background:rgba(100,116,139,.8);color:white;}
.quiz-detail{padding:10px 14px;background:#f8fafc;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--border);}
.total-skor-container{display:flex;align-items:center;gap:8px;}
.total-skor-label{font-size:12px;color:var(--gray);}
.total-skor-value{font-size:13px;font-weight:700;background:var(--gray-light);padding:3px 10px;border-radius:20px;color:var(--primary);}
.total-skor-value.completed{background:var(--success-light);color:#065f46;}
.status-badge{font-size:11px;padding:3px 10px;border-radius:20px;font-weight:700;}
.status-badge.selesai{background:var(--success-light);color:#065f46;}
.status-badge.belum{background:var(--danger-light);color:#991b1b;}
.btn-eval-toggle{width:100%;padding:11px 16px;border:none;background:linear-gradient(135deg,#e2e8f0,#f1f5f9);color:#334155;cursor:pointer;font-size:13px;font-weight:600;transition:.2s;display:flex;align-items:center;justify-content:center;gap:8px;border-top:1px solid #cbd5e1;}
.btn-eval-toggle:hover{background:linear-gradient(135deg,#cbd5e1,#e2e8f0);color:#1e293b;}
.btn-eval-toggle:active{transform:scale(0.98);background:#94a3b8;color:#fff;}
.btn-eval-toggle .eval-icon{font-size:16px;}
.reset-btn{width:100%;padding:12px;border:none;border-radius:14px;background:linear-gradient(135deg,#dc2626,#ef4444);color:white;cursor:pointer;margin-top:8px;font-weight:700;display:flex;align-items:center;justify-content:center;gap:8px;transition:.2s;}
.reset-btn:active{transform:scale(0.97);background:#b91c1c;box-shadow:0 0 0 4px rgba(220,38,38,.25);}
.back-btn{width:100%;padding:12px;border:none;border-radius:14px;background:linear-gradient(135deg,#475569,#64748b);color:white;cursor:pointer;margin-top:10px;font-weight:700;transition:.2s;}
.back-btn:active{transform:scale(0.97);background:#334155;box-shadow:0 0 0 4px rgba(71,85,105,.25);}
.info-block{border-radius:14px;padding:14px;margin-bottom:12px;}
.info-block p{line-height:1.7;margin-bottom:8px;color:#475569;font-size:14px;}
.materi-card{border:none;border-radius:16px;padding:18px;color:white;cursor:pointer;text-align:center;transition:.2s;display:flex;flex-direction:column;align-items:center;gap:8px;font-weight:700;font-size:16px;margin-bottom:12px;box-shadow:0 4px 14px rgba(0,0,0,.12);width:100%;min-height:100px;justify-content:center;}
.materi-card:active{transform:scale(0.96);}
.materi-card.twk{background:linear-gradient(135deg,#7c3aed,#a78bfa);}
.materi-card.tiu{background:linear-gradient(135deg,#b45309,#f59e0b);}
.materi-card.tkp{background:linear-gradient(135deg,#059669,#34d399);}
.materi-card .materi-icon{font-size:36px;}
.materi-card .materi-desc{font-size:12px;opacity:.9;line-height:1.4;}
.materi-content-full{background:white;border-radius:14px;padding:16px 18px;line-height:1.8;color:#334155;font-size:14px;text-align:justify;margin-bottom:0;min-height:200px;overflow-y:auto;}
.materi-content-full h2{color:var(--primary);margin-bottom:14px;font-size:19px;border-bottom:2px solid var(--border);padding-bottom:8px;}
.materi-content-full h3{color:var(--secondary);margin:18px 0 8px;font-size:15px;padding-left:10px;border-left:3px solid var(--secondary);}
.materi-content-full p{margin-bottom:10px;}
.materi-content-full ul,.materi-content-full ol{margin:8px 0 12px 22px;}
.materi-content-full li{margin-bottom:6px;}
.materi-content-full table{width:100%;border-collapse:collapse;margin:12px 0;}
.materi-content-full td,.materi-content-full th{border:1px solid var(--border);padding:9px;font-size:13px;}
.materi-content-full th{background:var(--gray-light);font-weight:700;}
.materi-content-full strong{color:var(--primary);}
.materi-content-full .info-box{background:#eff6ff;border-left:4px solid var(--primary);padding:11px 14px;border-radius:0 8px 8px 0;margin:12px 0;}
.materi-content-full .warning-box{background:var(--warning-light);border-left:4px solid var(--warning);padding:11px 14px;border-radius:0 8px 8px 0;margin:12px 0;}
.materi-content-full .tip-box{background:var(--success-light);border-left:4px solid var(--success);padding:11px 14px;border-radius:0 8px 8px 0;margin:12px 0;}
.materi-content-full.twk-bg{background:linear-gradient(135deg,#f5f3ff 0%,#ffffff 100%);}
.materi-content-full.tiu-bg{background:linear-gradient(135deg,#fffbeb 0%,#ffffff 100%);}
.materi-content-full.tkp-bg{background:linear-gradient(135deg,#ecfdf5 0%,#ffffff 100%);}
.materi-nav-bottom{display:flex;gap:10px;margin-top:0;flex-wrap:wrap;flex-shrink:0;padding:8px 0 0 0;border-top:1px solid var(--border);}
.materi-nav-bottom button{flex:1;min-width:100px;padding:11px;border:none;border-radius:12px;color:white;font-weight:700;font-size:13px;cursor:pointer;transition:.2s;display:flex;align-items:center;justify-content:center;gap:6px;}
.materi-nav-bottom button:active{transform:scale(0.96);}
.materi-nav-bottom .btn-twk{background:var(--secondary);}
.materi-nav-bottom .btn-tiu{background:#b45309;}
.materi-nav-bottom .btn-tkp{background:var(--success);}
#materiContentPage .card{display:flex;flex-direction:column;max-height:90vh;padding-bottom:14px;}
#materiContentPage .page-title{flex-shrink:0;position:sticky;top:0;background:white;z-index:10;padding-bottom:10px;margin-bottom:0;}
#materiContentPage #materiContentFull{flex:1;overflow-y:auto;max-height:none;min-height:200px;margin-bottom:0;padding-bottom:12px;}
#materiContentPage .materi-nav-bottom{flex-shrink:0;}
#materiContentPage .back-btn{flex-shrink:0;margin-top:6px;}
#quizPage{max-width:900px;}
.quiz-card{background:white;border-radius:18px;box-shadow:0 8px 30px rgba(30,58,138,.12);padding:22px;}
.quiz-top{margin-bottom:14px;padding-bottom:12px;border-bottom:2px solid var(--primary-light);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;}
.quiz-top h2{color:var(--primary);margin:0;font-size:17px;font-weight:800;}
.header-cat{font-weight:700;padding:4px 12px;border-radius:20px;font-size:12px;}
.header-cat.twk{background:var(--secondary-light);color:var(--secondary);border:1px solid var(--secondary);}
.header-cat.tiu{background:#fef3c7;color:#b45309;border:1px solid #b45309;}
.header-cat.tkp{background:var(--success-light);color:var(--success);border:1px solid var(--success);}
.quiz-info{display:flex;justify-content:space-between;margin-bottom:12px;font-weight:700;align-items:center;}
#timerDisplay{transition:color .3s;font-weight:800;font-size:18px;color:var(--dark);}
.timer-badge{font-size:11px;padding:2px 8px;border-radius:20px;margin-left:8px;}
.timer-badge.on{background:var(--success);color:white;}
.timer-badge.off{background:var(--danger);color:white;}
.timer-warning{color:var(--warning)!important;}
.timer-danger{color:var(--danger)!important;}
.timer-blink{color:var(--danger)!important;animation:blinkFast .5s ease infinite;font-weight:800;}
@keyframes blinkFast{0%,100%{opacity:1}50%{opacity:.2}}
.question-txt{font-size:15px;margin-bottom:16px;font-weight:700;line-height:1.65;color:var(--dark);text-align:justify;}
.question-txt img{max-width:100%;border-radius:8px;display:block;margin:8px 0;}
.option{display:flex;align-items:center;gap:12px;margin-bottom:9px;padding:12px;border:1.5px solid var(--border);border-radius:10px;cursor:pointer;transition:.2s;background:white;}
.option:hover{background:var(--gray-light);border-color:var(--primary);}
.option input{display:none;}
.choice-letter{width:36px;height:36px;min-width:36px;border-radius:50%;background:var(--primary);color:white;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:15px;}
.option input:checked+.choice-letter{background:var(--success);}
.option:has(input:checked){background:var(--success-light);border-color:var(--success);}
.choice-text{flex:1;font-size:14px;color:#334155;}
.btn-prev{padding:10px 20px;border:none;border-radius:10px;background:linear-gradient(135deg,#475569,#64748b);color:white;cursor:pointer;font-size:15px;font-weight:700;transition:.2s;min-width:100px;}
.btn-prev:active{transform:scale(0.93);background:#334155;box-shadow:0 0 0 4px rgba(71,85,105,.25);}
.btn-next{padding:10px 20px;border:none;border-radius:10px;background:linear-gradient(135deg,#2563eb,#3b82f6);color:white;cursor:pointer;font-size:15px;font-weight:700;transition:.2s;min-width:100px;}
.btn-next:active{transform:scale(0.93);background:#1d4ed8;box-shadow:0 0 0 4px rgba(37,99,235,.25);}
.btn-finish{padding:10px 20px;border:none;border-radius:10px;background:linear-gradient(135deg,#059669,#10b981);color:white;cursor:pointer;font-size:15px;font-weight:700;transition:.2s;min-width:100px;}
.btn-finish:active{transform:scale(0.93);background:#047857;box-shadow:0 0 0 4px rgba(5,150,105,.25);}
.sidebar-toggle{position:fixed;bottom:26px;left:50%;transform:translateX(-50%);z-index:1000;}
.btn-sidebar{background:linear-gradient(135deg,#2563eb,#4f46e5);color:white;border:2px solid rgba(255,255,255,.4);border-radius:50px;padding:11px 22px;font-size:15px;font-weight:700;cursor:pointer;box-shadow:inset 0 2px 4px rgba(255,255,255,.2),0 4px 20px rgba(37,99,235,.5),0 0 0 4px rgba(37,99,235,.15);display:flex;align-items:center;gap:8px;transition:.2s;animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{box-shadow:inset 0 2px 4px rgba(255,255,255,.2),0 4px 20px rgba(37,99,235,.5),0 0 0 4px rgba(37,99,235,.15)}50%{box-shadow:inset 0 2px 4px rgba(255,255,255,.2),0 4px 30px rgba(37,99,235,.7),0 0 0 8px rgba(37,99,235,.05)}}
.btn-sidebar:active{transform:scale(0.93);animation:none;box-shadow:inset 0 4px 8px rgba(0,0,0,.2),0 0 0 4px rgba(37,99,235,.25)}
.sidebar{position:fixed;top:0;right:-360px;width:340px;height:100vh;background:white;box-shadow:-4px 0 20px rgba(0,0,0,.12);z-index:1002;transition:right .3s ease;display:flex;flex-direction:column;overflow:hidden;}
.sidebar.open{right:0;}
.sidebar-header{padding:16px 18px;background:linear-gradient(135deg,#2563eb,#4f46e5);color:white;display:flex;justify-content:space-between;align-items:center;flex-shrink:0;}
.sidebar-header h3{margin:0;font-size:16px;}
.close-sidebar{background:none;border:none;color:white;font-size:26px;cursor:pointer;width:28px;height:28px;display:flex;align-items:center;justify-content:center;}
.soal-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;overflow-y:auto;}
.grid-soal{aspect-ratio:1;display:flex;align-items:center;justify-content:center;border-radius:8px;cursor:pointer;font-weight:700;font-size:13px;transition:.2s;border:2px solid var(--border);background:var(--gray-light);color:#475569;}
.grid-soal:active{transform:scale(0.9);}
.grid-soal.answered{background:var(--success);color:white;border-color:var(--success);}
.grid-soal.unanswered{background:var(--danger);color:white;border-color:var(--danger);}
.grid-soal.active{background:var(--primary);color:white;border-color:var(--primary);box-shadow:0 0 0 3px rgba(37,99,235,.3);}
.grid-soal.twk{border-left:4px solid var(--secondary);}
.grid-soal.tiu{border-left:4px solid #b45309;}
.grid-soal.tkp{border-left:4px solid var(--success);}
.grid-soal.active.twk,.grid-soal.active.tiu,.grid-soal.active.tkp{border-left:4px solid rgba(255,255,255,.6);}
.overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(15,23,42,.5);z-index:999;display:none;}
.overlay.show{display:block;}
.result-card{background:white;border-radius:18px;box-shadow:0 8px 30px rgba(30,58,138,.12);padding:22px;text-align:center;}
.result-card h1{margin-bottom:12px;color:var(--primary);font-size:22px;font-weight:800;}
.score-detail{text-align:left;max-width:440px;margin:14px auto;padding:14px;background:var(--gray-light);border-radius:12px;}
.score-detail h3{margin-bottom:10px;color:var(--primary);font-size:15px;font-weight:700;}
.score-detail table{width:100%;border-collapse:collapse;}
.score-detail td{padding:7px;border-bottom:1px solid var(--border);font-size:14px;}
.score-detail td:first-child{font-weight:700;color:#334155;}
.score-detail td:last-child{text-align:right;font-weight:700;}
.total-score{font-size:22px;font-weight:800;color:var(--success);margin-top:12px;}
.pass-status{margin-top:10px;padding:10px;border-radius:10px;text-align:center;font-weight:700;}
.result-btns{display:flex;gap:10px;justify-content:center;margin-top:18px;flex-wrap:wrap;}
.btn-restart{padding:10px 18px;border:none;border-radius:10px;background:linear-gradient(135deg,#059669,#10b981);color:white;cursor:pointer;font-size:14px;font-weight:700;transition:.2s;}
.btn-restart:active{transform:scale(0.93);background:#047857;box-shadow:0 0 0 4px rgba(5,150,105,.25);}
.btn-evaluasi{padding:10px 18px;border:none;border-radius:10px;background:linear-gradient(135deg,#7c3aed,#a78bfa);color:white;cursor:pointer;font-size:14px;font-weight:700;transition:.2s;}
.btn-evaluasi:active{transform:scale(0.93);background:#6d28d9;box-shadow:0 0 0 4px rgba(124,58,237,.25);}
.btn-home{padding:10px 18px;border:none;border-radius:10px;background:linear-gradient(135deg,#d97706,#f59e0b);color:white;cursor:pointer;font-size:14px;font-weight:700;transition:.2s;}
.btn-home:active{transform:scale(0.93);background:#b45309;box-shadow:0 0 0 4px rgba(217,119,6,.25);}
.evaluasi-panel{display:none;max-height:700px;overflow-y:auto;margin-top:16px;text-align:left;border-top:2px solid var(--primary-light);padding-top:16px;}
.evaluasi-item{background:var(--gray-light);border-radius:10px;padding:13px;margin-bottom:10px;border-left:5px solid var(--border);}
.evaluasi-item.benar{border-left-color:var(--success);background:#f0fdf4;}
.evaluasi-item.salah{border-left-color:var(--danger);background:#fff5f5;}
.evaluasi-item.belum{border-left-color:var(--warning);background:#fffbeb;}
.evaluasi-item .soal-teks{font-weight:700;margin-bottom:5px;font-size:13px;color:var(--dark);}
.evaluasi-item .soal-isi{font-size:13px;margin-bottom:7px;color:#475569;line-height:1.5;text-align:justify;}
.evaluasi-item .jawaban-user{font-size:13px;margin-bottom:4px;padding:6px 10px;border-radius:8px;background:#e2e8f0;}
.evaluasi-item .jawaban-benar{font-size:13px;margin-bottom:4px;padding:6px 10px;border-radius:8px;background:var(--success-light);color:#065f46;}
.evaluasi-item .pembahasan-box{margin-top:8px;padding:10px 12px;border-radius:8px;background:#eff6ff;border-left:3px solid var(--primary);font-size:12px;color:#1e3a8a;line-height:1.6;}
.evaluasi-item .pembahasan-box strong{display:block;margin-bottom:3px;color:var(--primary);font-size:11px;text-transform:uppercase;letter-spacing:.5px;}
.btn-close-eval{padding:10px 18px;border:none;border-radius:10px;background:linear-gradient(135deg,#475569,#64748b);color:white;cursor:pointer;margin-top:10px;font-weight:700;transition:.2s;}
.btn-close-eval:active{transform:scale(0.93);background:#334155;box-shadow:0 0 0 4px rgba(71,85,105,.25);}
.modal{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(15,23,42,.7);z-index:20000;justify-content:center;align-items:center;}
.modal.show{display:flex;}
.modal-content{background:white;padding:24px;border-radius:20px;max-width:300px;text-align:center;animation:fadeIn .3s ease;}
.modal-content h3{margin-bottom:10px;color:var(--dark);font-weight:800;}
.modal-content p{margin-bottom:16px;color:var(--gray);font-size:14px;}
.modal-btns{display:flex;gap:10px;justify-content:center;}
.modal-btns button{padding:9px 18px;border:none;border-radius:10px;cursor:pointer;font-weight:700;}
.btn-confirm{background:linear-gradient(135deg,#dc2626,#ef4444);color:white;}
.btn-cancel{background:linear-gradient(135deg,#475569,#64748b);color:white;}
.stats-overview{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:14px;}
.stats-mini-card{background:white;border-radius:14px;padding:14px 8px;text-align:center;box-shadow:0 2px 10px rgba(0,0,0,.07);border:1px solid var(--border);}
.stats-mini-card .mini-icon{font-size:26px;margin-bottom:4px;}
.stats-mini-card .mini-value{font-size:19px;font-weight:800;color:var(--primary);}
.stats-mini-card .mini-label{font-size:10px;color:var(--gray);margin-top:2px;font-weight:600;}
.stats-bar-container{margin:8px 0;}
.stats-bar-label{display:flex;justify-content:space-between;font-size:12px;font-weight:700;margin-bottom:4px;color:#334155;}
.stats-bar{height:18px;border-radius:10px;background:var(--gray-light);overflow:hidden;margin-bottom:10px;border:1px solid var(--border);}
.stats-bar-fill{height:100%;border-radius:10px;transition:width 0.6s ease;display:flex;align-items:center;justify-content:center;color:white;font-size:11px;font-weight:700;min-width:36px;}
.stats-bar-fill.twk{background:linear-gradient(90deg,#7c3aed,#a78bfa);}
.stats-bar-fill.tiu{background:linear-gradient(90deg,#b45309,#f59e0b);}
.stats-bar-fill.tkp{background:linear-gradient(90deg,#059669,#34d399);}
.stats-history-table{width:100%;border-collapse:collapse;font-size:12px;margin-top:8px;}
.stats-history-table th{background:var(--gray-light);padding:8px;text-align:center;font-size:11px;font-weight:700;color:#334155;}
.stats-history-table td{padding:8px;text-align:center;border-bottom:1px solid var(--border);font-size:12px;}
.stats-history-table .pass{color:var(--success);font-weight:700;}
.stats-history-table .fail{color:var(--danger);font-weight:700;}
.chart-container{background:white;border-radius:14px;padding:14px;margin-top:12px;border:1px solid var(--border);}
.chart-container h4{color:var(--dark);font-size:13px;font-weight:700;margin-bottom:12px;}
.chart-canvas-wrap{overflow-x:auto;}
canvas#progressChart{max-width:100%;height:180px;}
.pencapaian-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:4px;}
.badge-card{border-radius:14px;padding:14px 10px;text-align:center;border:2px solid var(--border);background:var(--gray-light);transition:.2s;}
.badge-card.unlocked{background:linear-gradient(135deg,#fffbeb,#fef3c7);border-color:#f59e0b;box-shadow:0 2px 10px rgba(245,158,11,.2);}
.badge-card .badge-icon{font-size:32px;margin-bottom:6px;}
.badge-card .badge-name{font-size:12px;font-weight:700;color:var(--dark);}
.badge-card .badge-desc{font-size:11px;color:var(--gray);margin-top:3px;line-height:1.4;}
.badge-card.locked .badge-icon{filter:grayscale(1);opacity:.4;}
.badge-card.locked .badge-name{color:var(--gray);}
.soal-salah-info{background:linear-gradient(135deg,#fff5f5,#ffe4e6);border:1px solid #fca5a5;border-radius:12px;padding:12px;margin-bottom:14px;font-size:13px;color:#991b1b;text-align:center;}
.btn-mulai-soal-salah{width:100%;padding:14px;border:none;border-radius:14px;background:linear-gradient(135deg,#be123c,#f43f5e);color:white;font-size:16px;font-weight:700;cursor:pointer;transition:.2s;margin-bottom:10px;}
.btn-mulai-soal-salah:active{transform:scale(0.97);box-shadow:0 0 0 4px rgba(190,18,60,.25);}
.btn-mulai-soal-salah:disabled{background:#cbd5e1;cursor:not-allowed;}
.simulasi-info{background:var(--warning-light);border-left:4px solid var(--warning);padding:14px;border-radius:0 12px 12px 0;margin-bottom:16px;font-size:13px;line-height:1.6;}
.simulasi-info strong{color:#92400e;}
.btn-mulai-simulasi{width:100%;padding:15px;border:none;border-radius:14px;background:linear-gradient(135deg,#dc2626,#ef4444);color:white;font-size:17px;font-weight:700;cursor:pointer;transition:.2s;}
.btn-mulai-simulasi:active{transform:scale(0.98);box-shadow:0 0 0 4px rgba(220,38,38,.25);}
.btn-mulai-simulasi:disabled{background:#cbd5e1;cursor:not-allowed;}
.screenshot-overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.9);z-index:99999;display:none;pointer-events:none;}
.watermark{position:fixed;bottom:6px;left:8px;font-size:8px;color:rgba(255,255,255,.15);z-index:100;pointer-events:none;}
.error-notice{background:var(--danger-light);border:1px solid #fca5a5;color:#991b1b;padding:13px;border-radius:10px;margin-bottom:12px;font-size:13px;display:none;}
/* Soal Salah skor box */
.soal-salah-skor-box{background:linear-gradient(135deg,#fff1f2,#ffe4e6);border:1px solid #fca5a5;border-radius:14px;padding:14px;margin:12px 0;text-align:center;}
.soal-salah-skor-box .skor-title{font-size:13px;color:#9f1239;font-weight:700;margin-bottom:8px;}
.soal-salah-skor-box .skor-grid{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;}
.soal-salah-skor-box .skor-pill{padding:6px 14px;border-radius:20px;font-size:12px;font-weight:700;}
@media(max-width:600px){
  .menu-grid-6{grid-template-columns:1fr 1fr;gap:8px;}
  .stats-overview{grid-template-columns:1fr 1fr 1fr;gap:6px;}
  .sidebar{width:100%;right:-100%;}
  .quiz-top{flex-direction:column;text-align:center;}
  .question-txt{font-size:14px;}
  .pencapaian-grid{grid-template-columns:1fr 1fr;}
}
</style>
</head>
