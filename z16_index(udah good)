function getCat(n){
  if(n<=30)return{name:'TWK',cls:'twk'};
  if(n<=65)return{name:'TIU',cls:'tiu'};
  return{name:'TKP',cls:'tkp'};
}

function shuffleOpts(q){
  const kat=q.kategori||'TKP';
  if(q.isTKP){
    let p=q.options.map((t,i)=>({text:t,score:q.optionScores[i]}));
    for(let i=p.length-1;i>0;i--){let j=Math.floor(Math.random()*(i+1));[p[i],p[j]]=[p[j],p[i]];}
    return{question:q.question,options:p.map(x=>x.text),answer:null,isTKP:true,optionScores:p.map(x=>x.score),pembahasan:q.pembahasan||'',kategori:kat};
  } else {
    let p=q.options.map((t,i)=>({text:t,idx:i}));
    for(let i=p.length-1;i>0;i--){let j=Math.floor(Math.random()*(i+1));[p[i],p[j]]=[p[j],p[i]];}
    return{question:q.question,options:p.map(x=>x.text),answer:p.findIndex(x=>x.idx===q.answer),isTKP:false,optionScores:null,pembahasan:q.pembahasan||'',kategori:kat};
  }
}

function getSoalBank(id){
  const v='paket'+id;
  return typeof window[v]!=='undefined'?window[v]:{twk:[],tiu:[],tkp:[]};
}

function buildOriginals(id){
  const bank=getSoalBank(id),orig=[];
  bank.twk.forEach(d=>orig.push({question:d.q,options:[...d.opt],answer:d.a,isTKP:false,optionScores:null,pembahasan:d.pembahasan||'',kategori:'TWK'}));
  bank.tiu.forEach(d=>orig.push({question:d.q,options:[...d.opt],answer:d.a,isTKP:false,optionScores:null,pembahasan:d.pembahasan||'',kategori:'TIU'}));
  bank.tkp.forEach(d=>orig.push({question:d.q,options:[...d.opts],answer:null,isTKP:true,optionScores:[...d.scores],pembahasan:d.pembahasan||'',kategori:'TKP'}));
  return orig;
}

function hitungSkor(){
  let twk=0,tiu=0,tkp=0;
  for(let i=0;i<questions.length;i++){
    const n=i+1;
    if(n<=30){if(userAnswers[i]!==null&&userAnswers[i]===questions[i].answer)twk+=5;}
    else if(n<=65){if(userAnswers[i]!==null&&userAnswers[i]===questions[i].answer)tiu+=5;}
    else{if(userScores[i]!==null)tkp+=userScores[i];}
  }
  return{twk,tiu,tkp,total:twk+tiu+tkp,persen:Math.round((twk+tiu+tkp)/550*100)};
}

function hitungSkorByKategori(){
  let twk=0,tiu=0,tkp=0;
  for(let i=0;i<questions.length;i++){
    const q=questions[i];const kat=q.kategori||'TKP';
    if(q.isTKP){if(userScores[i]!==null&&userScores[i]!==undefined)tkp+=userScores[i];}
    else{if(userAnswers[i]!==null&&userAnswers[i]===q.answer){
      if(kat==='TWK')twk+=5;else if(kat==='TIU')tiu+=5;else tkp+=5;
    }}
  }
  const total=twk+tiu+tkp;
  let mTWK=0,mTIU=0,mTKP=0;
  questions.forEach(q=>{
    const kat=q.kategori||'TKP';
    if(q.isTKP){const mx=q.optionScores?Math.max(...q.optionScores):5;mTKP+=mx;}
    else{if(kat==='TWK')mTWK+=5;else if(kat==='TIU')mTIU+=5;}
  });
  const mTot=mTWK+mTIU+mTKP;
  return{twk,tiu,tkp,total,persen:mTot>0?Math.round(total/mTot*100):0,mTWK,mTIU,mTKP,mTot};
}

