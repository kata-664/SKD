    hHtml+='</table>';
  } else {hHtml+='<p style="color:#94a3b8;text-align:center;padding:20px;">Belum ada riwayat latihan paket.</p>';}
  document.getElementById('statsHistory').innerHTML=hHtml;
  let qcHtml='<h4 style="margin:14px 0 8px;color:var(--dark);font-size:13px;font-weight:700;">⚡ Rekor Quiz Cepat</h4>';
  qcHtml+=`<table class="stats-history-table"><tr><th>Kategori</th><th>1 Menit</th><th>3 Menit</th><th>5 Menit</th><th>10 Menit</th><th>Sesi</th></tr>`;
  ['twk','tiu','tkp'].forEach(cat=>{
    const c=QC_CATS[cat];
    const sesi=getQCTotalSesi(cat);
    const b1=getQCBestScore(cat,1)||'-';const b3=getQCBestScore(cat,3)||'-';
    const b5=getQCBestScore(cat,5)||'-';const b10=getQCBestScore(cat,10)||'-';
    qcHtml+=`<tr><td style="font-weight:700;">${c.icon} ${c.name}</td><td>${b1}</td><td>${b3}</td><td>${b5}</td><td>${b10}</td><td>${sesi}</td></tr>`;
  });
  qcHtml+='</table>';
  document.getElementById('statsQCHistory').innerHTML=qcHtml;
}

function mulaiSimulasi(){
  const allTWK=[],allTIU=[],allTKP=[];
  for(let i=1;i<=5;i++){const b=getSoalBank(i);allTWK.push(...b.twk);allTIU.push(...b.tiu);allTKP.push(...b.tkp);}
  const pick=(arr,n)=>[...arr].sort(()=>Math.random()-.5).slice(0,Math.min(n,arr.length));
  const sTWK=pick(allTWK,30),sTIU=pick(allTIU,35),sTKP=pick(allTKP,45);
  if(sTWK.length+sTIU.length+sTKP.length===0){alert('⚠️ Tidak ada soal tersedia!');return;}
  if(timerInterval){clearInterval(timerInterval);timerInterval=null;}
  originals=[];
  sTWK.forEach(d=>originals.push({question:d.q,options:[...d.opt],answer:d.a,isTKP:false,optionScores:null,pembahasan:d.pembahasan||'',kategori:'TWK'}));
  sTIU.forEach(d=>originals.push({question:d.q,options:[...d.opt],answer:d.a,isTKP:false,optionScores:null,pembahasan:d.pembahasan||'',kategori:'TIU'}));
  sTKP.forEach(d=>originals.push({question:d.q,options:[...d.opts],answer:null,isTKP:true,optionScores:[...d.scores],pembahasan:d.pembahasan||'',kategori:'TKP'}));
  questions=originals.map(q=>shuffleOpts(q));
  curQ=0;userAnswers=Array(questions.length).fill(null);userScores=Array(questions.length).fill(null);
  timeLeft=6000;simulasiMode=true;activeSet=0;
  document.getElementById('evaluasiPanel').style.display='none';
  document.getElementById('btnCloseEval').style.display='none';
  document.getElementById('quizTitle').textContent='⏰ Simulasi Ujian SKD';
  goTo('quizPage'); // FIX #2: _showPage di dalam goTo akan otomatis show sidebar toggle
  loadQuestion();updateGrid();
  const td=document.getElementById('timerDisplay'),tb=document.getElementById('timerBadge');
  td.textContent='100:00';td.style.opacity='1';
  td.classList.remove('timer-warning','timer-danger','timer-blink');
  tb.textContent='⏱️ Simulasi';tb.className='timer-badge on';tb.style.display='';
  startTimer();
}

function startQuiz(setId){
  if(timerInterval){clearInterval(timerInterval);timerInterval=null;}
  const bank=getSoalBank(setId);
  if(bank.twk.length+bank.tiu.length+bank.tkp.length===0){alert(`⚠️ Paket ${setId} belum tersedia.`);return;}
  activeSet=setId;simulasiMode=false;
  originals=buildOriginals(setId);
  questions=originals.map(q=>shuffleOpts(q));
  curQ=0;userAnswers=Array(questions.length).fill(null);userScores=Array(questions.length).fill(null);
  timeLeft=6000;
  document.getElementById('evaluasiPanel').style.display='none';
  document.getElementById('btnCloseEval').style.display='none';
  document.getElementById('quizTitle').textContent=`📖 Latihan SKD Paket ${setId}`;
  goTo('quizPage'); // FIX #2: _showPage di dalam goTo akan otomatis show sidebar toggle
  loadQuestion();updateGrid();
  const timerOn=getTimerEnabled();
  const td=document.getElementById('timerDisplay'),tb=document.getElementById('timerBadge');
  tb.style.display='';
  if(timerOn){
    td.textContent='100:00';td.style.opacity='1';
    td.classList.remove('timer-warning','timer-danger','timer-blink');
    tb.textContent='⏱️ Timer ON';tb.className='timer-badge on';startTimer();
  } else {
    td.textContent='100:00';td.style.opacity='.5';
    tb.textContent='⏸️ Timer OFF';tb.className='timer-badge off';
  }
}

function loadQuestion(){
  const n=curQ+1;
  document.getElementById('quizProgress').textContent=`Soal ${n}/${questions.length}`;
  document.getElementById('quizQuestion').innerHTML=questions[curQ].question;
  const kat=questions[curQ].kategori||getCat(n).name;
  const katCls=kat.toLowerCase();
  const hc=document.getElementById('quizHeaderCat');
  hc.textContent=`📍 ${kat}`;hc.className=`header-cat ${katCls}`;
  let html='';
  questions[curQ].options.forEach((opt,idx)=>{
    let checked=questions[curQ].isTKP?(userScores[curQ]===questions[curQ].optionScores[idx]):(userAnswers[curQ]===idx);
    html+=`<label class="option" onclick="playSound('select')"><input type="radio" name="ans" value="${idx}" ${checked?'checked':''}><span class="choice-letter">${PREFIXES[idx]}</span><span class="choice-text">${opt}</span></label>`;
  });
  document.getElementById('quizOptions').innerHTML=html;
  const btn=document.getElementById('btnNextFinish');
  if(curQ===questions.length-1){btn.textContent='✅ Selesai';btn.className='btn-finish';btn.style.flex='1';btn.onclick=finishQuiz;}
  else{btn.textContent='Next ▶';btn.className='btn-next';btn.style.flex='1';btn.onclick=nextQuestion;}
  updateGrid();
}

function saveAnswer(){
  const sel=document.querySelector('input[name="ans"]:checked');
  if(sel){
    const idx=parseInt(sel.value);
    if(questions[curQ].isTKP)userScores[curQ]=questions[curQ].optionScores[idx];
    else userAnswers[curQ]=idx;
    updateGrid();
  }
}

function nextQuestion(){playSound('next');saveAnswer();if(curQ<questions.length-1){curQ++;loadQuestion();}}
function prevQuestion(){playSound('prev');saveAnswer();if(curQ>0){curQ--;loadQuestion();}}

function startTimer(){
  if(timerInterval)clearInterval(timerInterval);
  timerInterval=setInterval(()=>{
    if(timeLeft<=0){clearInterval(timerInterval);playSound('timeout');finishQuiz();return;}
    timeLeft--;
    const m=Math.floor(timeLeft/60),s=timeLeft%60;
    const el=document.getElementById('timerDisplay');
    el.textContent=`${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
    el.classList.remove('timer-warning','timer-danger','timer-blink');
    if(timeLeft<=20)el.classList.add('timer-blink');
    else if(timeLeft<=120)el.classList.add('timer-danger');
    else if(timeLeft<=300)el.classList.add('timer-warning');
  },1000);
}

function updateGrid(){
  const grid=document.getElementById('soalGrid');if(!grid)return;
  let html='';
  for(let i=0;i<questions.length;i++){
    let st='unanswered';
    if(questions[i].isTKP){if(userScores[i]!==null&&userScores[i]!==undefined)st='answered';}
    else{if(userAnswers[i]!==null)st='answered';}
    if(i===curQ)st='active';
    const kat=(questions[i].kategori||getCat(i+1).name).toLowerCase();
    html+=`<div class="grid-soal ${st} ${kat}" onclick="goToSoal(${i})">${i+1}</div>`;
  }
  grid.innerHTML=html;
}

function goToSoal(i){playSound('select');saveAnswer();curQ=i;loadQuestion();toggleSidebar();}
function toggleSidebar(){
  const sb=document.getElementById('sidebar'),ov=document.getElementById('overlay');
  const isOpen=sb.classList.toggle('open');
  if(isOpen){ov.style.width=`calc(100% - ${sb.offsetWidth}px)`;ov.classList.add('show');}
  else{ov.style.width='';ov.classList.remove('show');}
}

function finishQuiz(){
  if(timerInterval){clearInterval(timerInterval);timerInterval=null;}
  saveAnswer();
  // FIX #2: Saat selesai, sidebar toggle akan otomatis tersembunyi lewat goTo('resultPage')
  const wasSimulasi=simulasiMode;
  let s;
  if(!wasSimulasi){
    s=hitungSkor();
    const bank=getSoalBank(activeSet);
    s.mTWK=bank.twk.length*5||150;s.mTIU=bank.tiu.length*5||175;
    s.mTKP=bank.tkp.length*5||225;s.mTot=s.mTWK+s.mTIU+s.mTKP;
  } else {s=hitungSkorByKategori();}
  if(wasSimulasi){
    const simuCount=(parseInt(localStorage.getItem('simulasiCount')||'0'))+1;
    localStorage.setItem('simulasiCount',simuCount);
    const simuLulus=s.twk>=65&&s.tiu>=80&&s.tkp>=166;
    localStorage.setItem('simulasi_last',JSON.stringify({twk:s.twk,tiu:s.tiu,tkp:s.tkp,total:s.total,persen:s.persen,tanggal:new Date().toLocaleDateString('id-ID'),lulus:simuLulus}));
    if(simuLulus){const berturut=(parseInt(localStorage.getItem('simulasiLulusBerturut')||'0'))+1;localStorage.setItem('simulasiLulusBerturut',berturut);}
    else{localStorage.setItem('simulasiLulusBerturut','0');}
    simulasiMode=false;
  } else {
    incPaketUlangi(activeSet);
    localStorage.setItem(`skorTWK_latihan${activeSet}`,s.twk);
    localStorage.setItem(`skorTIU_latihan${activeSet}`,s.tiu);
    localStorage.setItem(`skorTKP_latihan${activeSet}`,s.tkp);
    const ed={answers:userAnswers,scores:userScores,questions:questions.map(q=>({question:q.question,options:q.options,answer:q.answer,isTKP:q.isTKP,optionScores:q.optionScores,pembahasan:q.pembahasan||'',kategori:q.kategori||''}))};
    localStorage.setItem(`evalData_latihan${activeSet}`,JSON.stringify(ed));
    const key=`bestScore_latihan${activeSet}`;
    const prev=localStorage.getItem(key);
    if(prev===null||s.total>parseInt(prev))localStorage.setItem(key,s.total);
  }
  const mTWK=s.mTWK||150,mTIU=s.mTIU||175,mTKP=s.mTKP||225;
  const mTot=s.mTot||(mTWK+mTIU+mTKP);
  document.getElementById('resultSubtitle').textContent=wasSimulasi?'⏰ Hasil Simulasi SKD':`📝 Latihan SKD Paket ${activeSet}`;
  document.getElementById('scoreDetail').innerHTML=`<h3>📊 Detail Skor</h3><table>
    <tr><td>📚 TWK</td><td><strong>${s.twk}</strong> / ${mTWK}</td></tr>
    <tr><td>🔢 TIU</td><td><strong>${s.tiu}</strong> / ${mTIU}</td></tr>
    <tr><td>⭐ TKP</td><td><strong>${s.tkp}</strong> / ${mTKP}</td></tr>
    <tr style="border-top:2px solid var(--border);"><td><strong>✅ TOTAL</strong></td><td><strong>${s.total}</strong> / ${mTot}</td></tr>
  </table><div class="total-score">🎯 Nilai Akhir: ${s.persen}%</div>`;
  const pass={twk:s.twk>=PASSING.TWK,tiu:s.tiu>=PASSING.TIU,tkp:s.tkp>=PASSING.TKP};
  pass.all=pass.twk&&pass.tiu&&pass.tkp;
  // Suara hasil
  playSound(pass.all?'finish':'wrong');
  document.getElementById('passStatus').style.display='';
  document.getElementById('passStatus').innerHTML=`
    <div style="margin-bottom:10px;font-weight:700;color:var(--dark);">📋 STATUS PASSING GRADE:</div>
    <div style="display:flex;gap:8px;flex-wrap:wrap;">
      <div style="flex:1;text-align:center;padding:9px;border-radius:10px;background:${pass.twk?'#d1fae5':'#fee2e2'};font-size:13px;">📚 TWK: ${s.twk}/65<br><strong>${pass.twk?'✅ LULUS':'❌ GAGAL'}</strong></div>
      <div style="flex:1;text-align:center;padding:9px;border-radius:10px;background:${pass.tiu?'#d1fae5':'#fee2e2'};font-size:13px;">🔢 TIU: ${s.tiu}/80<br><strong>${pass.tiu?'✅ LULUS':'❌ GAGAL'}</strong></div>
      <div style="flex:1;text-align:center;padding:9px;border-radius:10px;background:${pass.tkp?'#d1fae5':'#fee2e2'};font-size:13px;">⭐ TKP: ${s.tkp}/166<br><strong>${pass.tkp?'✅ LULUS':'❌ GAGAL'}</strong></div>
    </div>
    <div style="margin-top:12px;padding:12px;border-radius:10px;background:${pass.all?'#d1fae5':'#fee2e2'};font-weight:700;font-size:14px;">
      ${pass.all?'🎉 SELAMAT! Anda LULUS Passing Grade SKD!':'⚠️ Belum lulus passing grade. Terus semangat berlatih!'}
    </div>`;
  goTo('resultPage');
}

function restartQuiz(){if(activeSet>0)startQuiz(activeSet);else goTo('homePage');}
function backToHome(){
  if(timerInterval){clearInterval(timerInterval);timerInterval=null;}
  if(qcState.interval){clearInterval(qcState.interval);qcState.interval=null;}
  simulasiMode=false;goTo('homePage');refreshHomeStats();
}

function showEvaluasi(){
  const panel=document.getElementById('evaluasiPanel');
  let html='<h3 style="color:var(--primary);margin-bottom:12px;">📝 Evaluasi Jawaban</h3>';
  for(let i=0;i<questions.length;i++){
    const n=i+1;const katName=questions[i].kategori||getCat(n).name;
    const q=questions[i],pb=q.pembahasan||'';
    let jawUser='Tidak dijawab',jawBenar='',stCls='belum',stIcon='⏳';
    if(q.isTKP){
      if(userScores[i]!==null&&userScores[i]!==undefined){
        const uS=userScores[i],idx=q.optionScores.findIndex(s=>s===uS);
        jawUser=idx>=0?`${PREFIXES[idx]}. ${q.options[idx]} <span style="font-weight:700;color:#7c3aed">(Skor: ${uS})</span>`:'Tidak dijawab';
        const mS=Math.max(...q.optionScores),bIdx=q.optionScores.findIndex(s=>s===mS);
        jawBenar=`Terbaik: ${PREFIXES[bIdx]}. ${q.options[bIdx]} <strong>(${mS})</strong>`;
        stCls=uS===mS?'benar':'salah';stIcon=uS===mS?'✅':'❌';
      }
    } else {
      if(userAnswers[i]!==null){
        jawUser=`${PREFIXES[userAnswers[i]]}. ${q.options[userAnswers[i]]}`;
        jawBenar=`${PREFIXES[q.answer]}. ${q.options[q.answer]}`;
        stCls=userAnswers[i]===q.answer?'benar':'salah';stIcon=userAnswers[i]===q.answer?'✅':'❌';
      }
    }
    let stLabel=stCls==='benar'?'<span style="color:#059669;font-weight:700;font-size:12px;">BENAR</span>':
      stCls==='salah'?'<span style="color:#dc2626;font-weight:700;font-size:12px;">SALAH</span>':
      '<span style="color:#d97706;font-weight:700;font-size:12px;">BELUM</span>';
    html+=`<div class="evaluasi-item ${stCls}">
      <div class="soal-teks">${stIcon} Soal ${n} [${katName}] — ${stLabel}</div>
      <div class="soal-isi">${q.question}</div>
      <div class="jawaban-user">📌 <strong>Jawaban Anda:</strong> ${jawUser}</div>
      ${jawBenar?`<div class="jawaban-benar">✅ <strong>Jawaban Benar:</strong> ${jawBenar}</div>`:''}
      ${pb?`<div class="pembahasan-box"><strong>💡 Pembahasan</strong><br>${pb}</div>`:''}
    </div>`;
  }
  panel.innerHTML=html;panel.style.display='block';
  document.getElementById('btnCloseEval').style.display='block';
  panel.scrollIntoView({behavior:'smooth',block:'start'});
}

function closeEvaluasi(){
  document.getElementById('evaluasiPanel').style.display='none';
  document.getElementById('btnCloseEval').style.display='none';
}

function showResetModal(){document.getElementById('resetModal').classList.add('show');}
function closeResetModal(){document.getElementById('resetModal').classList.remove('show');}
function resetAllProgress(){
  for(let i=1;i<=5;i++){
    ['bestScore','skorTWK','skorTIU','skorTKP'].forEach(k=>localStorage.removeItem(`${k}_latihan${i}`));
    localStorage.removeItem(`evalData_latihan${i}`);
    localStorage.removeItem(`paketUlangi_${i}`);
  }
  localStorage.removeItem('simulasi_last');
  localStorage.removeItem('simulasiCount');
  localStorage.removeItem('simulasiLulusBerturut');
  localStorage.removeItem('materiOpened');
  localStorage.removeItem('menuVisited');
  ['twk','tiu','tkp'].forEach(cat=>{
    [1,3,5,10].forEach(m=>localStorage.removeItem(`qcBest_${cat}_${m}m`));
    localStorage.removeItem(`qcTotalSesi_${cat}`);
    localStorage.removeItem(`qcStreakMax_${cat}`);
    localStorage.removeItem(`qcNoWrong_${cat}`);
    localStorage.removeItem(`qcAkurasi90_${cat}`);
  });
  refreshQuizList();refreshHomeStats();closeResetModal();
  playSound('back');
  alert('✅ Semua progress telah direset!');
}
</script>
