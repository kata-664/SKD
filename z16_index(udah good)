// ==================== NAVIGATION CORE ====================
const PAGES = ['homePage','quizlistPage','materiPage','materiContentPage','statistikPage','simulasiPage',
  'petunjukPage','tentangPage','quizPage','resultPage','evaluasiListPage','pencapaianPage',
  'quizCepatPage','quizCepatConfirmPage','quizCepatPlayPage','quizCepatResultPage','akunPage','loginPage'];

// Halaman yang BOLEH menampilkan tombol Daftar Soal
const PAGES_WITH_SIDEBAR = ['quizPage'];

let currentPage = 'loginPage';

function _showPage(pageId){
  PAGES.forEach(p=>{
    const el=document.getElementById(p);
    if(el){el.classList.remove('active');el.style.display='';}
  });
  const target=document.getElementById(pageId);
  if(target) target.classList.add('active');
  currentPage = pageId;
  window.scrollTo(0,0);

  // FIX #2: Tampilkan/sembunyikan tombol Daftar Soal sesuai halaman aktif
  if(PAGES_WITH_SIDEBAR.includes(pageId)){
    showSidebarToggle();
  } else {
    hideSidebarToggle();
  }
}

function goTo(pageId){
  if(currentPage===pageId) return;
  if(pageId!=='loginPage' && !getLoggedInUser()) return;

  // Stop timer quiz jika keluar dari halaman quiz
  if(currentPage==='quizPage' && pageId!=='quizPage'){
    if(timerInterval){clearInterval(timerInterval);timerInterval=null;}
  }
  // Stop QC timer jika keluar dari play page
  if(currentPage==='quizCepatPlayPage' && pageId!=='quizCepatPlayPage'){
    if(qcState&&qcState.interval){clearInterval(qcState.interval);qcState.interval=null;}
  }

  _showPage(pageId);
  saveActivePage(pageId);

  // Tandai kunjungan menu
  const menuMap={quizlistPage:'latihan',materiPage:'materi',statistikPage:'statistik',
    simulasiPage:'simulasi',petunjukPage:'petunjuk',tentangPage:'tentang',
    pencapaianPage:'pencapaian',quizCepatPage:'quizcepat',akunPage:'akun'};
  if(menuMap[pageId]) markMenuVisited(menuMap[pageId]);

  // Refresh konten halaman
  if(pageId==='quizlistPage') refreshQuizList();
  if(pageId==='homePage'){refreshHomeStats();refreshHomeUsername();}
  if(pageId==='statistikPage') refreshStatistik();
  if(pageId==='pencapaianPage') refreshPencapaian();
  if(pageId==='quizCepatPage') renderQuizCepatGrid();
  if(pageId==='akunPage') refreshAkunPage();

  history.pushState({page: pageId}, '', '');
}

// ==================== ANDROID BACK BUTTON ====================
window.addEventListener('popstate', function(e){
  const state = e.state;

  // Tutup sidebar jika terbuka
  const sb = document.getElementById('sidebar');
  if(sb && sb.classList.contains('open')){
    toggleSidebar();
    history.pushState({page: currentPage}, '', '');
    return;
  }

  // Tutup modal jika terbuka
  const modals = ['logoutModal','resetModal'];
  let modalClosed = false;
  modals.forEach(id=>{
    const m = document.getElementById(id);
    if(m && (m.classList.contains('show') || m.style.display==='flex')){
      m.classList.remove('show');
      modalClosed = true;
    }
  });
  if(modalClosed){
    history.pushState({page: currentPage}, '', '');
    return;
  }

  // Jika di loginPage atau homePage, biarkan sistem Android yang tangani
  if(currentPage === 'loginPage' || currentPage === 'homePage'){
    history.pushState({page: currentPage}, '', '');
    return;
  }

  // Halaman lain → kembali ke parent
  playSound('back');
  const parent = PAGE_PARENT[currentPage] || 'homePage';

  // Stop timer jika keluar dari quiz
  if(currentPage==='quizPage'){
    if(timerInterval){clearInterval(timerInterval);timerInterval=null;}
  }
  if(currentPage==='quizCepatPlayPage'){
    if(qcState&&qcState.interval){clearInterval(qcState.interval);qcState.interval=null;}
  }

  _showPage(parent);
  saveActivePage(parent);

  if(parent==='homePage'){refreshHomeStats();refreshHomeUsername();}
  if(parent==='quizlistPage') refreshQuizList();
  if(parent==='quizCepatPage') renderQuizCepatGrid();

  history.pushState({page: parent}, '', '');
});

// ==================== APP INIT ====================
(function initApp(){
  const user = getLoggedInUser();
  if(user){
    const lastPage = getLastActivePage();
    const restorable = PAGES.filter(p => !NON_RESTORABLE_PAGES.includes(p));
    const targetPage = restorable.includes(lastPage) ? lastPage : 'homePage';

    _showPage(targetPage);
    refreshHomeStats();
    refreshHomeUsername();

    if(targetPage==='quizlistPage') refreshQuizList();
    if(targetPage==='statistikPage') refreshStatistik();
    if(targetPage==='pencapaianPage') refreshPencapaian();
    if(targetPage==='quizCepatPage') renderQuizCepatGrid();
    if(targetPage==='akunPage') refreshAkunPage();

    if(targetPage !== 'homePage'){
      history.replaceState({page: 'homePage'}, '', '');
      history.pushState({page: targetPage}, '', '');
    } else {
      history.replaceState({page: 'homePage'}, '', '');
    }
  } else {
    _showPage('loginPage');
    history.replaceState({page: 'loginPage'}, '', '');
  }
})();

