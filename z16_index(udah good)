// ==================== LOGIN UI ====================
function togglePasswordVisibility(){
  const inp = document.getElementById('inputPassword');
  const btn = document.getElementById('btnEye');
  if(inp.type==='password'){inp.type='text';btn.textContent='🙈';}
  else{inp.type='password';btn.textContent='👁️';}
}

function doLogin(){
  const u = document.getElementById('inputUsername').value.trim().toLowerCase();
  const p = document.getElementById('inputPassword').value;
  const errEl = document.getElementById('loginError');
  if(!u||!p){
    errEl.textContent='⚠️ Username dan password tidak boleh kosong!';
    errEl.classList.add('show'); return;
  }
  const pengguna = typeof daftarPengguna!=='undefined' ? daftarPengguna : [];
  const match = pengguna.find(x=>x.username.toLowerCase()===u && x.password===p);
  if(match){
    errEl.classList.remove('show');
    setLoggedInUser(match.username);
    document.getElementById('inputUsername').value='';
    document.getElementById('inputPassword').value='';
    document.getElementById('btnEye').textContent='👁️';
    document.getElementById('inputPassword').type='password';
    playSound('login');
    _showPage('homePage', true);
    refreshHomeStats();
  } else {
    playSound('wrong');
    errEl.textContent='⚠️ Username atau password salah!';
    errEl.classList.add('show');
    document.getElementById('inputPassword').value='';
    document.getElementById('inputPassword').focus();
  }
}

