function shuffleQCSoal(arr){const a=[...arr];for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}return a;}

function shuffleQCOpts(d){
  if(d.isTKP){
    let p=d.opt.map((t,i)=>({text:t,score:d.scores[i]}));
    for(let i=p.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[p[i],p[j]]=[p[j],p[i]];}
    return{...d,opt:p.map(x=>x.text),scores:p.map(x=>x.score)};
  } else {
    let p=d.opt.map((t,i)=>({text:t,idx:i}));
    for(let i=p.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[p[i],p[j]]=[p[j],p[i]];}
    return{...d,opt:p.map(x=>x.text),a:p.findIndex(x=>x.idx===d.a)};
  }
}

function mulaiQuizCepat(){
  if(qcState.interval){clearInterval(qcState.interval);qcState.interval=null;}
  const cat=qcState.cat;const menit=qcState.timerMenit;
  const rawSoal=getQCSoal(cat);
  if(!rawSoal||rawSoal.length===0){alert('Soal tidak tersedia!');return;}
  const soalShuffled=shuffleQCSoal(rawSoal).map(d=>{
    const isTKP=d.isTKP||(d.scores&&!d.a&&d.a!==0)||false;
    if(isTKP)return{q:d.q,opt:[...(d.opt||d.opts||[])],scores:[...(d.scores||[])],isTKP:true,pembahasan:d.pembahasan||''};
    else return{q:d.q,opt:[...(d.opt||[])],a:d.a!==undefined?d.a:0,isTKP:false,pembahasan:d.pembahasan||''};
  }).map(d=>shuffleQCOpts(d));
  qcState.soal=soalShuffled;qcState.curIdx=0;qcState.benar=0;qcState.salah=0;
  qcState.totalDijawab=0;qcState.timeLeft=menit*60;qcState.totalWaktu=menit*60;
  qcState.streakCur=0;qcState.streakMax=0;qcState.noWrong=true;
  goTo('quizCepatPlayPage');renderQCQuestion();startQCTimer();
}

function renderQCQuestion(){
  const soal=qcState.soal;const idx=qcState.curIdx;
  if(idx>=soal.length){finishQuizCepat();return;}
  const d=soal[idx];const c=QC_CATS[qcState.cat];
  document.getElementById('qcPlayCat').textContent=`${c.icon} ${c.name}`;
  document.getElementById('qcPlayCat').className=`qc-play-cat ${qcState.cat}`;
  document.getElementById('qcPlayScore').textContent=`Soal ke-${idx+1}`;
  document.getElementById('qcCorrectCount').textContent=`✅ ${qcState.benar} Benar`;
  document.getElementById('qcQNum').textContent=`SOAL ${idx+1}`;
  document.getElementById('qcQTxt').innerHTML=d.q;
  let optsHtml='';
  d.opt.forEach((o,i)=>{
    optsHtml+=`<div class="qc-opt" onclick="playSound('select');pilihQCJawaban(${i})">
      <div class="qc-opt-letter">${PREFIXES[i]}</div>
      <div class="qc-opt-text">${o}</div>
    </div>`;
  });
  document.getElementById('qcOpts').innerHTML=optsHtml;
  const fb=document.getElementById('qcFeedback');
  fb.className='qc-feedback';fb.textContent='';
  const btnNext=document.getElementById('btnQcNext');
  btnNext.className='btn-qc-next';btnNext.textContent='Soal Berikutnya →';
}

function pilihQCJawaban(idx){
  const soal=qcState.soal[qcState.curIdx];
  const opts=document.querySelectorAll('.qc-opt');
  opts.forEach(o=>{o.classList.add('disabled');o.onclick=null;});
  const fb=document.getElementById('qcFeedback');
  let isBenar=false;
  if(soal.isTKP){
    const maxScore=Math.max(...soal.scores);const chosen=soal.scores[idx];
    opts[idx].classList.add(chosen===maxScore?'correct':'wrong');
    if(chosen!==maxScore){const bestIdx=soal.scores.findIndex(s=>s===maxScore);if(bestIdx>=0)opts[bestIdx].classList.add('correct');}
    opts.forEach((optEl,i)=>{
      const textEl=optEl.querySelector('.qc-opt-text');
      if(textEl&&!textEl.querySelector('.qc-score-reveal')){
        const scoreSpan=document.createElement('span');
        scoreSpan.className='qc-score-reveal';
        scoreSpan.style.cssText='font-size:11px;margin-left:6px;font-weight:700;';
        scoreSpan.textContent=`(${soal.scores[i]} poin)`;textEl.appendChild(scoreSpan);
      }
    });
    isBenar=(chosen===maxScore);
    fb.textContent=isBenar?`✅ Tepat! Skor maksimal: ${maxScore}`:`❌ Skor kamu: ${chosen} poin | Skor terbaik: ${maxScore} poin`;
    fb.className='qc-feedback '+(isBenar?'benar':'salah');
  } else {
    opts[idx].classList.add(idx===soal.a?'correct':'wrong');
    if(idx!==soal.a)opts[soal.a].classList.add('correct');
    isBenar=(idx===soal.a);
    fb.textContent=isBenar?'✅ Benar!':'❌ Salah! Jawaban benar: '+PREFIXES[soal.a]+'. '+soal.opt[soal.a];
    fb.className='qc-feedback '+(isBenar?'benar':'salah');
  }
  // Suara benar/salah di QC
  playSound(isBenar?'correct':'wrong');
  if(isBenar){qcState.benar++;qcState.streakCur++;if(qcState.streakCur>qcState.streakMax)qcState.streakMax=qcState.streakCur;}
  else{qcState.salah++;qcState.streakCur=0;qcState.noWrong=false;}
  qcState.totalDijawab++;
  document.getElementById('qcCorrectCount').textContent=`✅ ${qcState.benar} Benar`;
  const btnNext=document.getElementById('btnQcNext');
  btnNext.className='btn-qc-next show';btnNext.onclick=qcNextQuestion;
  if(qcState.curIdx>=qcState.soal.length-1){btnNext.textContent='🏁 Lihat Hasil';btnNext.onclick=finishQuizCepat;}
}

function qcNextQuestion(){playSound('next');qcState.curIdx++;if(qcState.curIdx>=qcState.soal.length)finishQuizCepat();else renderQCQuestion();}

function startQCTimer(){
  if(qcState.interval)clearInterval(qcState.interval);
  updateQCTimerDisplay();
  qcState.interval=setInterval(()=>{
    qcState.timeLeft--;updateQCTimerDisplay();
    if(qcState.timeLeft<=0){clearInterval(qcState.interval);qcState.interval=null;playSound('timeout');finishQuizCepat();}
  },1000);
}

function updateQCTimerDisplay(){
  const el=document.getElementById('qcPlayTimer');
  const prog=document.getElementById('qcProgressFill');
  const m=Math.floor(qcState.timeLeft/60),s=qcState.timeLeft%60;
  el.textContent=`${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
  el.className='qc-play-timer';
  if(qcState.timeLeft<=10)el.classList.add('danger');
  else if(qcState.timeLeft<=30)el.classList.add('warning');
  const pct=Math.max(0,(qcState.timeLeft/qcState.totalWaktu)*100);
  prog.style.width=pct+'%';
  prog.style.background=qcState.timeLeft<=10?'linear-gradient(90deg,#dc2626,#ef4444)':
    qcState.timeLeft<=30?'linear-gradient(90deg,#d97706,#f59e0b)':
    'linear-gradient(90deg,#2563eb,#7c3aed)';
}

function finishQuizCepat(){
  if(qcState.interval){clearInterval(qcState.interval);qcState.interval=null;}
  const cat=qcState.cat;const menit=qcState.timerMenit;
  const benar=qcState.benar;const salah=qcState.salah;const total=qcState.totalDijawab;
  const c=QC_CATS[cat];
  incQCTotalSesi(cat);
  const isNewBest=setQCBestScore(cat,menit,benar);
  setQCStreakMax(cat,qcState.streakMax);
  if(qcState.noWrong&&total>0)setQCNoWrongBest(cat,total);
  if(total>0&&Math.round(benar/total*100)>=90)setQCAkurasi90(cat,true);
  const pct=total>0?Math.round(benar/total*100):0;
  let icon='😅',title='Terus Semangat!';
  if(pct>=90){icon='🏆';title='Luar Biasa!';}
  else if(pct>=70){icon='🎯';title='Bagus Sekali!';}
  else if(pct>=50){icon='💪';title='Cukup Baik!';}
  document.getElementById('qcResIcon').textContent=icon;
  document.getElementById('qcResTitle').textContent=title;
  document.getElementById('qcResCat').textContent=`${c.name} · ${menit} Menit`;
  document.getElementById('qcResSkor').textContent=benar;
  document.getElementById('qcResSub').textContent=`soal dijawab dengan benar dari ${total} soal`;
  document.getElementById('qcStatBenar').textContent=benar;
  document.getElementById('qcStatSalah').textContent=salah;
  document.getElementById('qcStatTotal').textContent=total;
  const newBestEl=document.getElementById('qcNewBest');
  newBestEl.style.display=isNewBest&&benar>0?'block':'none';
  if(isNewBest&&benar>0) playSound('newbest');
  else playSound('finish');
  const bestOverall=getQCBestScore(cat,menit);
  document.getElementById('qcBestInfo').innerHTML=`
    <div style="display:flex;gap:8px;flex-wrap:wrap;justify-content:center;align-items:center;">
      <span style="font-size:13px;color:var(--gray);">🏆 Rekor ${menit} menit:</span>
      <span style="font-size:16px;font-weight:800;color:${c.color};">${bestOverall} benar</span>
      ${total>0?`<span style="font-size:12px;color:var(--gray);">· Akurasi: ${pct}%</span>`:''}
    </div>`;
  goTo('quizCepatResultPage');
}

