function getQCSoal(cat){
  const varName=QC_CATS[cat].jsVar;
  if(typeof window[varName]!=='undefined')return window[varName];
  let all=[];
  for(let i=1;i<=5;i++){
    const b=getSoalBank(i);
    if(cat==='twk')b.twk.forEach(d=>all.push({q:d.q,opt:[...d.opt],a:d.a,isTKP:false,pembahasan:d.pembahasan||''}));
    else if(cat==='tiu')b.tiu.forEach(d=>all.push({q:d.q,opt:[...d.opt],a:d.a,isTKP:false,pembahasan:d.pembahasan||''}));
    else if(cat==='tkp')b.tkp.forEach(d=>all.push({q:d.q,opt:[...d.opts],scores:[...d.scores],isTKP:true,pembahasan:d.pembahasan||''}));
  }
  return all;
}

function getQCBestScore(cat,menit){return parseInt(localStorage.getItem(`qcBest_${cat}_${menit}m`)||'0');}
function setQCBestScore(cat,menit,val){
  const prev=getQCBestScore(cat,menit);
  if(val>prev)localStorage.setItem(`qcBest_${cat}_${menit}m`,val);
  return val>prev;
}
function getQCTotalSesi(cat){return parseInt(localStorage.getItem(`qcTotalSesi_${cat}`)||'0');}
function incQCTotalSesi(cat){localStorage.setItem(`qcTotalSesi_${cat}`,getQCTotalSesi(cat)+1);}
function getQCStreakMax(cat){return parseInt(localStorage.getItem(`qcStreakMax_${cat}`)||'0');}
function setQCStreakMax(cat,val){const p=getQCStreakMax(cat);if(val>p)localStorage.setItem(`qcStreakMax_${cat}`,val);}
function getQCNoWrongBest(cat){return parseInt(localStorage.getItem(`qcNoWrong_${cat}`)||'0');}
function setQCNoWrongBest(cat,val){const p=getQCNoWrongBest(cat);if(val>p)localStorage.setItem(`qcNoWrong_${cat}`,val);}
function getQCAkurasi90(cat){return parseInt(localStorage.getItem(`qcAkurasi90_${cat}`)||'0');}
function setQCAkurasi90(cat,achieved){if(achieved)localStorage.setItem(`qcAkurasi90_${cat}`,'1');}
function getQCAnyAkurasi90(){return ['twk','tiu','tkp'].some(c=>parseInt(localStorage.getItem(`qcAkurasi90_${c}`)||'0')===1);}

