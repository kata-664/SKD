// ==================== SOUND ENGINE (Web Audio API) ====================
let audioCtx = null;
function getAudioCtx(){
  if(!audioCtx){try{audioCtx=new(window.AudioContext||window.webkitAudioContext)();}catch(e){}}
  return audioCtx;
}
function playTone(freq, type, duration, gain, delay=0){
  const ctx=getAudioCtx();if(!ctx)return;
  const o=ctx.createOscillator();
  const g=ctx.createGain();
  o.connect(g);g.connect(ctx.destination);
  o.type=type;o.frequency.setValueAtTime(freq,ctx.currentTime+delay);
  g.gain.setValueAtTime(gain,ctx.currentTime+delay);
  g.gain.exponentialRampToValueAtTime(0.001,ctx.currentTime+delay+duration);
  o.start(ctx.currentTime+delay);
  o.stop(ctx.currentTime+delay+duration);
}
function playSound(type){
  try{
    switch(type){
      case 'menu':    // klik menu — dua nada naik singkat
        playTone(440,'sine',0.08,0.15);
        playTone(660,'sine',0.08,0.1,0.07);
        break;
      case 'back':    // kembali — nada turun
        playTone(440,'sine',0.06,0.12);
        playTone(330,'sine',0.08,0.1,0.06);
        break;
      case 'select':  // pilih jawaban — klik ringan
        playTone(600,'sine',0.06,0.12);
        break;
      case 'correct': // benar — fanfare naik
        playTone(523,'triangle',0.12,0.2);
        playTone(659,'triangle',0.12,0.2,0.12);
        playTone(784,'triangle',0.15,0.2,0.24);
        break;
      case 'wrong':   // salah — nada rendah
        playTone(220,'sawtooth',0.08,0.15);
        playTone(180,'sawtooth',0.1,0.12,0.1);
        break;
      case 'next':    // next soal — klik kecil
        playTone(520,'sine',0.05,0.1);
        break;
      case 'prev':    // prev soal — klik kecil turun
        playTone(400,'sine',0.05,0.1);
        break;
      case 'start':   // mulai — ascending chord
        playTone(392,'triangle',0.1,0.15);
        playTone(523,'triangle',0.1,0.15,0.1);
        playTone(659,'triangle',0.12,0.15,0.2);
        break;
      case 'finish':  // selesai — victory jingle
        playTone(523,'triangle',0.15,0.2);
        playTone(659,'triangle',0.15,0.2,0.15);
        playTone(784,'triangle',0.15,0.2,0.30);
        playTone(1047,'triangle',0.2,0.25,0.48);
        break;
      case 'timeout': // waktu habis — alarm
        playTone(880,'square',0.1,0.2);
        playTone(440,'square',0.1,0.2,0.15);
        playTone(880,'square',0.1,0.2,0.30);
        break;
      case 'login':   // login berhasil
        playTone(440,'sine',0.1,0.15);
        playTone(554,'sine',0.1,0.15,0.12);
        playTone(659,'sine',0.12,0.18,0.24);
        break;
      case 'newbest': // rekor baru
        playTone(523,'triangle',0.1,0.2);
        playTone(659,'triangle',0.1,0.2,0.1);
        playTone(784,'triangle',0.1,0.2,0.2);
        playTone(1047,'triangle',0.15,0.25,0.32);
        playTone(1319,'triangle',0.2,0.3,0.5);
        break;
    }
  }catch(e){}
}

