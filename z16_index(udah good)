function getBadgeStats(){
  let totalDone=0,totalLulus=0,bestScore=0,bestTWK=0,bestTIU=0,simulasiDone=0,simulasiLulus=false;
  for(let i=1;i<=5;i++){
    const twk=localStorage.getItem(`skorTWK_latihan${i}`);
    const tiu=localStorage.getItem(`skorTIU_latihan${i}`);
    const tkp=localStorage.getItem(`skorTKP_latihan${i}`);
    if(twk&&tiu&&tkp){
      totalDone++;
      const t=parseInt(twk)||0,u=parseInt(tiu)||0,k=parseInt(tkp)||0;
      if(t>=65&&u>=80&&k>=166)totalLulus++;
      if(t+u+k>bestScore)bestScore=t+u+k;
      if(t>bestTWK)bestTWK=t;
      if(u>bestTIU)bestTIU=u;
    }
  }
  try{
    const s=localStorage.getItem('simulasi_last');
    if(s){const d=JSON.parse(s);simulasiLulus=d.twk>=65&&d.tiu>=80&&d.tkp>=166;}
  }catch(e){}
  const simuCount=parseInt(localStorage.getItem('simulasiCount')||'0');
  simulasiDone=simuCount;
  const simulasiLulusBerturut=parseInt(localStorage.getItem('simulasiLulusBerturut')||'0');
  const qcSesiTWK=getQCTotalSesi('twk');
  const qcSesiTIU=getQCTotalSesi('tiu');
  const qcSesiTKP=getQCTotalSesi('tkp');
  const qcTotalSesi=qcSesiTWK+qcSesiTIU+qcSesiTKP;
  const qcBestTWK=Math.max(...[1,3,5,10].map(m=>getQCBestScore('twk',m)));
  const qcBestTIU=Math.max(...[1,3,5,10].map(m=>getQCBestScore('tiu',m)));
  const qcBestTKP=Math.max(...[1,3,5,10].map(m=>getQCBestScore('tkp',m)));
  const qcBest1m=Math.max(getQCBestScore('twk',1),getQCBestScore('tiu',1),getQCBestScore('tkp',1));
  const qcBest5m=Math.max(getQCBestScore('twk',5),getQCBestScore('tiu',5),getQCBestScore('tkp',5));
  const qcBest10m=Math.max(getQCBestScore('twk',10),getQCBestScore('tiu',10),getQCBestScore('tkp',10));
  const qcStreakMaxAll=Math.max(...['twk','tiu','tkp'].map(c=>getQCStreakMax(c)));
  const qcNoWrongAny=['twk','tiu','tkp'].some(c=>getQCNoWrongBest(c)>0);
  const qcAkurasi90=['twk','tiu','tkp'].some(c=>parseInt(localStorage.getItem(`qcAkurasi90_${c}`)||'0')===1);
  const materiOpened=getMateriOpened();
  const materiAll=materiOpened.twk&&materiOpened.tiu&&materiOpened.tkp;
  const menuVisited=getMenuVisited();
  const menuAll=['latihan','materi','statistik','simulasi','petunjuk','tentang','pencapaian','quizcepat'].every(m=>menuVisited[m]);
  const menuVisitedTentang=!!menuVisited['tentang'];
  const paketUlangiMax=getPaketUlangiMax();
  let pernahJawab=false;
  for(let i=1;i<=5;i++){if(localStorage.getItem(`evalData_latihan${i}`))pernahJawab=true;}
  const skorNaik=checkSkorNaik();
  return{totalDone,totalLulus,bestScore,bestTWK,bestTIU,simulasiDone,simulasiLulus,simulasiLulusBerturut,qcTotalSesi,qcSesiTWK,qcSesiTIU,qcSesiTKP,qcBestTWK,qcBestTIU,qcBestTKP,qcBest1m,qcBest5m,qcBest10m,qcStreakMaxAll,qcNoWrongAny,qcAkurasi90,materiAll,menuAll,menuVisitedTentang,paketUlangiMax,skorNaik,pernahJawab};
}

