  const scores=[];for(let i=1;i<=5;i++){const b=localStorage.getItem(`bestScore_latihan${i}`);if(b)scores.push({id:i,s:parseInt(b)});}
  if(scores.length<2)return false;
  for(let i=1;i<scores.length;i++){if(scores[i].s<=scores[i-1].s)return false;}
  return true;
}

