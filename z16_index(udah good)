function refreshAkunPage(){
  const u=getLoggedInUser()||'—';
  const setEl=(id,val)=>{const e=document.getElementById(id);if(e)e.textContent=val;};
  setEl('akunUsername',u);setEl('akunUsernameInfo',u);
  let best=[],done=0,lulus=0;
  for(let i=1;i<=5;i++){
    const twk=localStorage.getItem(`skorTWK_latihan${i}`);
    const tiu=localStorage.getItem(`skorTIU_latihan${i}`);
    const tkp=localStorage.getItem(`skorTKP_latihan${i}`);
    if(twk&&tiu&&tkp){done++;const t=parseInt(twk)||0,u2=parseInt(tiu)||0,k=parseInt(tkp)||0;best.push(t+u2+k);if(t>=65&&u2>=80&&k>=166)lulus++;}
  }
  setEl('akunBestScore',best.length>0?Math.max(...best)+' / 550':'Belum ada');
  setEl('akunPaketDone',done+' / 5');setEl('akunLulus',lulus+' paket');
  const qcSesi=['twk','tiu','tkp'].reduce((s,c)=>s+getQCTotalSesi(c),0);
  setEl('akunQCSesi',qcSesi+' sesi');
}

